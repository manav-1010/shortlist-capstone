@{
    Layout = "_Layout";
}

<style>
    :root {
        /* Core light professional theme */
        --bg: #f5f7fb;
        --bg2: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --surface-tint: #eef2ff;
        --border: #dbe3ee;
        --border-strong: #cbd5e1;
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: #e9e7ff;
        --success: #15803d;
        --success-soft: #e8f7ee;
        --shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
        --shadow-soft: 0 10px 24px rgba(15, 23, 42, 0.06);
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    /* Full-page soft background */
    body {
        background: radial-gradient(1000px 500px at 10% -5%, rgba(79,70,229,0.10), transparent 60%), radial-gradient(900px 460px at 100% 0%, rgba(34,197,94,0.08), transparent 58%), linear-gradient(180deg, var(--bg), var(--bg2));
        color: var(--text);
    }

    .content {
        padding-top: 18px !important;
    }

    .home-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 16px 28px;
    }

    .hero {
        position: relative;
        border-radius: 24px;
        padding: 32px 28px;
        overflow: hidden;
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.10), transparent 60%), radial-gradient(560px 240px at 92% 18%, rgba(34,197,94,0.08), transparent 55%), linear-gradient(180deg, #ffffff, #f8fbff);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 22px;
        align-items: center;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--surface-tint);
        border: 1px solid #d8d4fe;
        color: var(--accent);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: 0.2px;
        width: fit-content;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--success);
        box-shadow: 0 0 0 4px rgba(21,128,61,0.14);
    }

    .hero h1 {
        margin: 14px 0 10px;
        font-size: 44px;
        line-height: 1.06;
        letter-spacing: -0.8px;
        font-weight: 950;
        color: var(--text);
    }

    .hero p {
        margin: 0;
        font-size: 15.5px;
        line-height: 1.6;
        color: var(--muted);
        max-width: 60ch;
    }

    .cta-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .btnx {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 11px 14px;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        text-decoration: none;
        font-weight: 900;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
        user-select: none;
        min-width: 170px;
        box-shadow: var(--shadow-soft);
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: #f8fafc;
            border-color: #c4d0df;
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border: 1px solid var(--accent);
            color: #ffffff;
            box-shadow: 0 16px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
                border-color: var(--accent-hover);
            }

        .btnx .arrow {
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(255,255,255,0.18);
            font-size: 12px;
            font-weight: 950;
        }

    .hint-line {
        margin-top: 12px;
        color: var(--muted2);
        font-weight: 800;
        font-size: 12px;
    }

    .hero-card {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #f8fafc);
        padding: 14px;
        box-shadow: var(--shadow-soft);
    }

    .stat {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        padding: 13px;
        border-radius: 15px;
        background: var(--surface-soft);
        border: 1px solid var(--border);
        margin-bottom: 10px;
    }

        .stat:last-child {
            margin-bottom: 0;
        }

    .label {
        color: var(--muted2);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: .2px;
    }

    .value {
        font-size: 16px;
        font-weight: 950;
        color: var(--text);
    }

    .pill {
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 900;
        font-size: 12px;
        border: 1px solid var(--border);
        background: #f8fafc;
        color: var(--text);
        white-space: nowrap;
    }

        .pill.accent {
            border-color: #bbf7d0;
            background: var(--success-soft);
            color: var(--success);
        }

        .pill.blue {
            border-color: #c7d2fe;
            background: var(--accent-soft);
            color: var(--accent);
        }

    .below {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 14px;
        align-items: stretch;
    }

    .panel {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #fbfdff);
        box-shadow: var(--shadow-soft);
        padding: 18px;
    }

        .panel h2 {
            margin: 0 0 8px;
            font-size: 18px;
            font-weight: 950;
            letter-spacing: -0.2px;
            color: var(--text);
        }

        .panel p {
            margin: 0 0 12px;
            color: var(--muted);
            line-height: 1.6;
            font-size: 14px;
        }

    .bullets {
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
        line-height: 1.75;
        font-weight: 700;
        font-size: 14px;
    }

    .mini-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .mini {
        border-radius: 14px;
        padding: 12px;
        border: 1px solid var(--border);
        background: var(--surface-soft);
    }

        .mini .t {
            font-weight: 950;
            margin: 0 0 4px;
            color: var(--text);
        }

        .mini .d {
            margin: 0;
            color: var(--muted);
            font-weight: 750;
            font-size: 13px;
            line-height: 1.55;
        }

    .how {
        margin-top: 14px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #fbfdff);
        padding: 14px 16px;
        box-shadow: var(--shadow-soft);
    }

    .how-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

    .how-title {
        margin: 0;
        font-size: 18px;
        font-weight: 950;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .how-sub {
        margin: 0;
        color: var(--muted2);
        font-weight: 800;
        font-size: 12px;
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .step {
        border-radius: 14px;
        padding: 12px;
        border: 1px solid var(--border);
        background: var(--surface-soft);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: start;
        min-height: 70px;
    }

    .num {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 950;
        background: var(--accent-soft);
        border: 1px solid #c7d2fe;
        color: var(--accent);
    }

    .st {
        margin: 0;
        font-weight: 950;
        font-size: 13px;
        color: var(--text);
    }

    .sd {
        margin: 2px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 12.5px;
        line-height: 1.45;
    }

    @@media (max-width: 900px) {
        .hero-grid {
            grid-template-columns: 1fr;
        }

        .below {
            grid-template-columns: 1fr;
        }

        .steps {
            grid-template-columns: 1fr;
        }

        .hero h1 {
            font-size: 36px;
        }
    }
</style>

<div class="home-wrap">

    <section class="hero">
        <div class="hero-grid">
            <div>
                <div class="badge">
                    <span class="dot"></span>
                    Real-time neighborhood shortlisting for Kitchener–Waterloo
                </div>

                <h1>Pick priorities. Drop a pin. Get the best areas — fast.</h1>

                <p>
                    Shortlist helps students and renters in KW find neighborhoods that match what matters most —
                    using live map data to surface nearby places by priority.
                </p>

                <div class="cta-row">
                    <a class="btnx primary" href="/Filters/Index">
                        Start with Filters <span class="arrow">→</span>
                    </a>
                    <a class="btnx" href="/Results/Index">
                        View Results <span class="arrow">↗</span>
                    </a>
                    <a class="btnx" href="/SavedSearches/Index">
                        Saved <span class="arrow">★</span>
                    </a>
                </div>

                <div class="hint-line">
                    Tip: Filters → pick a location → Apply → see map markers → Save search.
                </div>
            </div>

            <div class="hero-card">
                <div class="stat">
                    <div>
                        <div class="label">Live Map</div>
                        <div class="value">OpenStreetMap + Leaflet</div>
                    </div>
                    <div class="pill blue">FREE</div>
                </div>
                <div class="stat">
                    <div>
                        <div class="label">Real-time Places</div>
                        <div class="value">Nearby matches by priority</div>
                    </div>
                    <div class="pill accent">LIVE</div>
                </div>
                <div class="stat">
                    <div>
                        <div class="label">Saved Searches</div>
                        <div class="value">Load / reuse in 1 click</div>
                    </div>
                    <div class="pill">PRO</div>
                </div>
            </div>
        </div>
    </section>

    <section class="below">
        <div class="panel">
            <h2>What the app does</h2>
            <p>Built for KW students: choose a location and instantly see what’s nearby.</p>
            <ul class="bullets">
                <li>Drop a pin and search within your radius (2–5 km typical).</li>
                <li>Pick up to 3 priorities (grocery, transit, parks, gym, parking, laundry).</li>
                <li>Get live map markers + save the setup for later.</li>
            </ul>
        </div>

        <div class="panel">
            <h2>Why it feels “real”</h2>
            <div class="mini-grid">
                <div class="mini">
                    <div class="t">⚡ Live data</div>
                    <p class="d">Results come from real OpenStreetMap queries.</p>
                </div>
                <div class="mini">
                    <div class="t">🗺️ Map-first UX</div>
                    <p class="d">Pick an area visually, not through long forms.</p>
                </div>
                <div class="mini">
                    <div class="t">💾 Saved searches</div>
                    <p class="d">One click reload for demos + real users.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="how">
        <div class="how-head">
            <h2 class="how-title">How it works</h2>
            <p class="how-sub">Fast, demo-friendly flow</p>
        </div>

        <div class="steps">
            <div class="step">
                <div class="num">1</div>
                <div>
                    <p class="st">Budget + distance</p>
                    <p class="sd">Shape your shortlist.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">2</div>
                <div>
                    <p class="st">Pick a map location</p>
                    <p class="sd">Drop a pin in KW.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">3</div>
                <div>
                    <p class="st">Choose priorities</p>
                    <p class="sd">Up to 3.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">4</div>
                <div>
                    <p class="st">See results + save</p>
                    <p class="sd">Reuse anytime.</p>
                </div>
            </div>
        </div>
    </section>

</div>