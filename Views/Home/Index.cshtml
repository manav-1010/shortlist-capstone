@{
    Layout = "_Layout";
}

<style>
    .content {
        padding-top: 22px !important;
    }

    .home-wrap {
        max-width: 1120px;
        margin: 0 auto;
        padding: 18px 16px 34px;
    }

    .hero {
        position: relative;
        border-radius: 28px;
        padding: 34px 30px;
        overflow: hidden;
        background: radial-gradient(760px 300px at 12% 0%, rgba(79, 70, 229, 0.16), transparent 56%), radial-gradient(620px 260px at 94% 18%, rgba(37, 99, 235, 0.10), transparent 54%), linear-gradient(180deg, var(--surface-strong), var(--surface));
        border: 1px solid var(--border);
        box-shadow: var(--shadow-xl);
        backdrop-filter: blur(16px);
    }

        .hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.10), transparent 42%);
            pointer-events: none;
        }

    .hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.18fr 0.82fr;
        gap: 24px;
        align-items: center;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 13px;
        border-radius: 999px;
        background: var(--surface-tint);
        border: 1px solid rgba(99, 102, 241, 0.20);
        color: var(--accent);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: 0.2px;
        width: fit-content;
        box-shadow: var(--shadow-md);
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--good);
        box-shadow: 0 0 0 4px var(--good-soft);
    }

    .hero h1 {
        margin: 16px 0 12px;
        font-size: 48px;
        line-height: 1.03;
        letter-spacing: -1px;
        font-weight: 950;
        color: var(--text);
        max-width: 12ch;
    }

    .hero p {
        margin: 0;
        font-size: 16px;
        line-height: 1.72;
        color: var(--muted);
        max-width: 60ch;
    }

    .cta-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .btnx {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 15px;
        border-radius: 14px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        text-decoration: none;
        font-weight: 900;
        cursor: pointer;
        transition: transform .14s ease, background .14s ease, border .14s ease, box-shadow .14s ease;
        user-select: none;
        min-width: 176px;
        box-shadow: var(--shadow-md);
    }

        .btnx:hover {
            transform: translateY(-2px);
            background: var(--surface-soft);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1 55%, #7c3aed);
            border: 1px solid transparent;
            color: #ffffff;
            box-shadow: 0 18px 38px rgba(79,70,229,0.24);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

        .btnx .arrow {
            width: 19px;
            height: 19px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(255,255,255,0.20);
            font-size: 12px;
            font-weight: 950;
        }

    .hint-line {
        margin-top: 14px;
        color: var(--muted2);
        font-weight: 800;
        font-size: 12px;
    }

    .hero-card {
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        padding: 16px;
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(14px);
    }

    .stat {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        padding: 14px;
        border-radius: 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        margin-bottom: 10px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
    }

        .stat:last-child {
            margin-bottom: 0;
        }

    .label {
        color: var(--muted2);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: .2px;
    }

    .value {
        font-size: 17px;
        font-weight: 950;
        color: var(--text);
    }

    .pill {
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 900;
        font-size: 12px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        white-space: nowrap;
    }

        .pill.accent {
            border-color: rgba(21, 128, 61, 0.22);
            background: var(--good-soft);
            color: var(--good);
        }

        .pill.blue {
            border-color: rgba(37, 99, 235, 0.20);
            background: var(--accent-soft);
            color: var(--accent);
        }

    .below {
        margin-top: 16px;
        display: grid;
        grid-template-columns: 1.18fr 0.82fr;
        gap: 14px;
        align-items: stretch;
    }

    .panel {
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        backdrop-filter: blur(12px);
        box-shadow: var(--shadow-lg);
        padding: 20px;
    }

        .panel h2 {
            margin: 0 0 8px;
            font-size: 18px;
            font-weight: 950;
            letter-spacing: -0.2px;
            color: var(--text);
        }

        .panel p {
            margin: 0 0 12px;
            color: var(--muted);
            line-height: 1.68;
            font-size: 14px;
        }

    .bullets {
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
        line-height: 1.82;
        font-weight: 700;
        font-size: 14px;
    }

    .mini-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .mini {
        border-radius: 16px;
        padding: 13px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface), var(--surface-soft));
        box-shadow: var(--shadow-md);
    }

        .mini .t {
            font-weight: 950;
            margin: 0 0 4px;
            color: var(--text);
        }

        .mini .d {
            margin: 0;
            color: var(--muted);
            font-weight: 750;
            font-size: 13px;
            line-height: 1.6;
        }

    .how {
        margin-top: 16px;
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        padding: 16px 18px;
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(12px);
    }

    .how-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 12px;
    }

    .how-title {
        margin: 0;
        font-size: 18px;
        font-weight: 950;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .step {
        border-radius: 16px;
        padding: 14px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface), var(--surface-soft));
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: start;
        min-height: 78px;
        box-shadow: var(--shadow-md);
    }

    .num {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 950;
        background: linear-gradient(135deg, rgba(79,70,229,0.14), rgba(56,189,248,0.10));
        border: 1px solid rgba(79,70,229,0.16);
        color: var(--accent);
    }

    .st {
        margin: 0;
        font-weight: 950;
        font-size: 13px;
        color: var(--text);
    }

    .sd {
        margin: 3px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 12.5px;
        line-height: 1.5;
    }

    @@media (max-width: 900px) {
        .hero-grid {
            grid-template-columns: 1fr;
        }

        .below {
            grid-template-columns: 1fr;
        }

        .steps {
            grid-template-columns: 1fr;
        }

        .hero h1 {
            font-size: 38px;
            max-width: none;
        }

        .hero {
            padding: 28px 22px;
        }
    }
</style>

<div class="home-wrap">

    <section class="hero">
        <div class="hero-grid">
            <div>
                <div class="badge">
                    <span class="dot"></span>
                    Real-time neighborhood shortlisting for Kitchener–Waterloo
                </div>

                <h1>Pick priorities. Drop a pin. Get the best areas — fast.</h1>

                <p>
                    Shortlist helps students and renters in KW find neighborhoods that match what matters most —
                    using live map data to surface nearby places by priority.
                </p>

                <div class="cta-row">
                    <a class="btnx primary" href="/Filters/Index">
                        Start with Filters <span class="arrow">→</span>
                    </a>
                    <a class="btnx" href="/Results/Index">
                        View Results <span class="arrow">↗</span>
                    </a>
                    <a class="btnx" href="/SavedSearches/Index">
                        Saved <span class="arrow">★</span>
                    </a>
                </div>

                <div class="hint-line">
                    Tip: Filters → pick a location → Apply → see map markers → Save search.
                </div>
            </div>

            <div class="hero-card">
                <div class="stat">
                    <div>
                        <div class="label">Live Map</div>
                        <div class="value">OpenStreetMap + Leaflet</div>
                    </div>
                    <div class="pill blue">FREE</div>
                </div>
                <div class="stat">
                    <div>
                        <div class="label">Real-time Places</div>
                        <div class="value">Nearby matches by priority</div>
                    </div>
                    <div class="pill accent">LIVE</div>
                </div>
                <div class="stat">
                    <div>
                        <div class="label">Saved Searches</div>
                        <div class="value">Load / reuse in 1 click</div>
                    </div>
                    <div class="pill">PRO</div>
                </div>
            </div>
        </div>
    </section>

    <section class="below">
        <div class="panel">
            <h2>What the app does</h2>
            <p>Built for KW students: choose a location and instantly see what’s nearby.</p>
            <ul class="bullets">
                <li>Drop a pin and search within your radius (2–5 km typical).</li>
                <li>Pick up to 3 priorities (grocery, transit, parks, gym, parking, laundry).</li>
                <li>Get live map markers + save the setup for later.</li>
            </ul>
        </div>

        <div class="panel">
            <h2>Why it feels “real”</h2>
            <div class="mini-grid">
                <div class="mini">
                    <div class="t">⚡ Live data</div>
                    <p class="d">Results come from real OpenStreetMap queries.</p>
                </div>
                <div class="mini">
                    <div class="t">🗺️ Map-first UX</div>
                    <p class="d">Pick an area visually, not through long forms.</p>
                </div>
                <div class="mini">
                    <div class="t">💾 Saved searches</div>
                    <p class="d">One click reload for demos + real users.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="how">
        <div class="how-head">
            <h2 class="how-title">How it works</h2>
        </div>

        <div class="steps">
            <div class="step">
                <div class="num">1</div>
                <div>
                    <p class="st">Budget + distance</p>
                    <p class="sd">Shape your shortlist.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">2</div>
                <div>
                    <p class="st">Pick a map location</p>
                    <p class="sd">Drop a pin in KW.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">3</div>
                <div>
                    <p class="st">Choose priorities</p>
                    <p class="sd">Up to 3.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">4</div>
                <div>
                    <p class="st">See results + save</p>
                    <p class="sd">Reuse anytime.</p>
                </div>
            </div>
        </div>
    </section>

</div>