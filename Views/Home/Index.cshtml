@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg: #0b0d12;
        --surface: rgba(255,255,255,0.06);
        --surface2: rgba(255,255,255,0.10);
        --border: rgba(255,255,255,0.12);
        --text: rgba(255,255,255,0.92);
        --muted: rgba(255,255,255,0.72);
        --accent: #4f46e5;
        --accent2: #22c55e;
        --shadow: 0 18px 60px rgba(0,0,0,0.35);
    }

    /* Fit content on one screen */
    .home-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 16px 18px;
    }

    .hero {
        position: relative;
        border-radius: 22px;
        padding: 26px 26px;
        overflow: hidden;
        background: radial-gradient(900px 380px at 20% 0%, rgba(79,70,229,0.42), transparent 60%), radial-gradient(700px 320px at 90% 30%, rgba(34,197,94,0.25), transparent 55%), linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.04));
        border: 1px solid rgba(255,255,255,0.14);
        box-shadow: var(--shadow);
        color: var(--text);
    }

        /* Add dark overlay behind text area so it’s readable */
        .hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(700px 360px at 18% 35%, rgba(0,0,0,0.55), transparent 70%), linear-gradient(90deg, rgba(0,0,0,0.42), transparent 65%);
            pointer-events: none;
        }

    .hero-grid {
        position: relative; /* above overlay */
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 18px;
        align-items: center;
    }

    .badge {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(0,0,0,0.35);
        border: 1px solid rgba(255,255,255,0.16);
        color: rgba(255,255,255,0.82);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: .2px;
        width: fit-content;
        backdrop-filter: blur(8px);
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--accent2);
        box-shadow: 0 0 0 3px rgba(34,197,94,0.18);
    }

    .hero h1 {
        margin: 12px 0 8px;
        font-size: 38px;
        line-height: 1.10;
        letter-spacing: -0.8px;
        font-weight: 950;
        color: rgba(255,255,255,0.96);
        text-shadow: 0 10px 26px rgba(0,0,0,0.35);
    }

    .hero p {
        margin: 0;
        font-size: 15px;
        line-height: 1.55;
        color: rgba(255,255,255,0.82);
        max-width: 62ch;
    }

    .cta-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .btnx {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 11px 14px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.18);
        background: rgba(0,0,0,0.30);
        color: rgba(255,255,255,0.92);
        text-decoration: none;
        font-weight: 950;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease, border .12s ease;
        user-select: none;
        min-width: 165px;
        backdrop-filter: blur(8px);
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: rgba(0,0,0,0.40);
            border-color: rgba(255,255,255,0.26);
        }

        .btnx.primary {
            background: linear-gradient(135deg, rgba(79,70,229,0.95), rgba(79,70,229,0.70));
            border: 1px solid rgba(79,70,229,0.55);
            box-shadow: 0 16px 40px rgba(79,70,229,0.25);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, rgba(79,70,229,1), rgba(79,70,229,0.78));
            }

        .btnx .arrow {
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(255,255,255,0.16);
            font-size: 12px;
            font-weight: 950;
        }

    .tip {
        margin-top: 10px;
        color: rgba(255,255,255,0.68);
        font-weight: 800;
        font-size: 12px;
    }

    .hero-card {
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(0,0,0,0.32);
        padding: 14px;
        backdrop-filter: blur(10px);
    }

    .stat {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        padding: 11px;
        border-radius: 14px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.10);
        margin-bottom: 10px;
    }

        .stat:last-child {
            margin-bottom: 0;
        }

    .label {
        color: rgba(255,255,255,0.66);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: .2px;
    }

    .value {
        font-size: 15px;
        font-weight: 950;
        color: rgba(255,255,255,0.92);
    }

    .pill {
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 950;
        font-size: 12px;
        border: 1px solid rgba(255,255,255,0.16);
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.92);
        white-space: nowrap;
        height: fit-content;
        align-self: start;
    }

        .pill.accent {
            border-color: rgba(34,197,94,0.35);
            background: rgba(34,197,94,0.12);
        }

        .pill.blue {
            border-color: rgba(79,70,229,0.35);
            background: rgba(79,70,229,0.12);
        }

    /* Compact “How it works” to avoid scrolling */
    .mini {
        margin-top: 12px;
        border-radius: 18px;
        background: #fff;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 14px 16px;
    }

        .mini h2 {
            margin: 0;
            font-size: 18px;
            font-weight: 950;
            color: #0d1320;
            letter-spacing: -0.2px;
        }

        .mini p {
            margin: 4px 0 10px;
            color: #4b5563;
            font-weight: 700;
            font-size: 13px;
        }

    .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .step {
        border-radius: 14px;
        padding: 10px 10px;
        border: 1px solid rgba(0,0,0,0.08);
        background: #fff;
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

    .num {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 950;
        background: rgba(34,197,94,0.12);
        border: 1px solid rgba(34,197,94,0.22);
        color: #065f46;
        flex: 0 0 auto;
    }

    .st-title {
        margin: 0;
        font-weight: 950;
        color: #0d1320;
        font-size: 13px;
        line-height: 1.25;
    }

    .st-desc {
        margin: 2px 0 0;
        color: #4b5563;
        font-weight: 700;
        font-size: 12px;
        line-height: 1.35;
    }

    @@media (max-width: 900px) {
        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero h1 {
            font-size: 32px;
        }

        .steps {
            grid-template-columns: 1fr;
        }

        .btnx {
            min-width: 150px;
        }
    }
</style>

<div class="home-wrap">

    <section class="hero">
        <div class="hero-grid">
            <div>
                <div class="badge">
                    <span class="dot"></span>
                    Real-time neighborhood shortlisting for Kitchener–Waterloo
                </div>

                <h1>Pick priorities. Drop a pin. Get the best areas — fast.</h1>

                <p>
                    Shortlist helps students and renters quickly find neighborhoods that match what matters most
                    using live map data: grocery, transit, parks, gym/fitness, parking, and more.
                </p>

                <div class="cta-row">
                    <a class="btnx primary" href="/Filters/Index">
                        Start with Filters <span class="arrow">→</span>
                    </a>
                    <a class="btnx" href="/Results/Index">
                        View Results <span class="arrow">↗</span>
                    </a>
                    <a class="btnx" href="/SavedSearches/Index">
                        Saved <span class="arrow">★</span>
                    </a>
                </div>

                <div class="tip">
                    Tip: Filters → pick a location on the map → Apply Filters → Save your search.
                </div>
            </div>

            <div class="hero-card">
                <div class="stat">
                    <div>
                        <div class="label">Live Map</div>
                        <div class="value">OpenStreetMap + Leaflet</div>
                    </div>
                    <div class="pill blue">FREE</div>
                </div>

                <div class="stat">
                    <div>
                        <div class="label">Real-time Places</div>
                        <div class="value">Nearby matches by priority</div>
                    </div>
                    <div class="pill accent">LIVE</div>
                </div>

                <div class="stat">
                    <div>
                        <div class="label">Saved Searches</div>
                        <div class="value">One-click load / reuse</div>
                    </div>
                    <div class="pill">PRO</div>
                </div>
            </div>
        </div>
    </section>

    <section class="mini">
        <h2>How it works</h2>
        <p>Fast, simple flow (perfect for demo).</p>

        <div class="steps">
            <div class="step">
                <div class="num">1</div>
                <div>
                    <p class="st-title">Set budget + distance</p>
                    <p class="st-desc">Shape your shortlist.</p>
                </div>
            </div>

            <div class="step">
                <div class="num">2</div>
                <div>
                    <p class="st-title">Pick a map location</p>
                    <p class="st-desc">Drop a pin in KW.</p>
                </div>
            </div>

            <div class="step">
                <div class="num">3</div>
                <div>
                    <p class="st-title">Choose priorities</p>
                    <p class="st-desc">Up to 3.</p>
                </div>
            </div>

            <div class="step">
                <div class="num">4</div>
                <div>
                    <p class="st-title">See results + save</p>
                    <p class="st-desc">Reuse anytime.</p>
                </div>
            </div>
        </div>
    </section>

</div>