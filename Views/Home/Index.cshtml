@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg: #0b0d12;
        --bg2: #07090d;
        --surface: rgba(255,255,255,0.06);
        --surface2: rgba(255,255,255,0.10);
        --border: rgba(255,255,255,0.12);
        --text: rgba(255,255,255,0.92);
        --muted: rgba(255,255,255,0.70);
        --muted2: rgba(255,255,255,0.55);
        --accent: #4f46e5;
        --accent2: #22c55e;
        --shadow: 0 18px 60px rgba(0,0,0,0.35);
    }

    /* FULL-PAGE DARK BACKGROUND */
    body {
        background: radial-gradient(1200px 700px at 20% -10%, rgba(79,70,229,0.18), transparent 60%), radial-gradient(900px 600px at 90% 0%, rgba(34,197,94,0.12), transparent 55%), linear-gradient(180deg, var(--bg), var(--bg2));
        color: var(--text);
    }

    /* Reduce wasted space from layout if any */
    .content {
        padding-top: 18px !important;
    }

    .home-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 16px 28px;
    }

    .hero {
        position: relative;
        border-radius: 22px;
        padding: 30px 26px;
        overflow: hidden;
        background: radial-gradient(900px 380px at 20% 0%, rgba(79,70,229,0.45), transparent 60%), radial-gradient(700px 320px at 90% 30%, rgba(34,197,94,0.28), transparent 55%), linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.02));
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 22px;
        align-items: center;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(0,0,0,0.28);
        border: 1px solid rgba(255,255,255,0.14);
        color: var(--muted);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: 0.2px;
        width: fit-content;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--accent2);
        box-shadow: 0 0 0 3px rgba(34,197,94,0.18);
    }

    .hero h1 {
        margin: 14px 0 10px;
        font-size: 44px;
        line-height: 1.06;
        letter-spacing: -0.8px;
        font-weight: 950;
        text-shadow: 0 10px 28px rgba(0,0,0,0.25);
    }

    .hero p {
        margin: 0;
        font-size: 15.5px;
        line-height: 1.55;
        color: var(--muted);
        max-width: 60ch;
    }

    .cta-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .btnx {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 11px 14px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(0,0,0,0.22);
        color: var(--text);
        text-decoration: none;
        font-weight: 950;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease, border .12s ease;
        user-select: none;
        min-width: 170px;
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,0.10);
            border-color: rgba(255,255,255,0.22);
        }

        .btnx.primary {
            background: linear-gradient(135deg, rgba(79,70,229,0.98), rgba(79,70,229,0.62));
            border: 1px solid rgba(79,70,229,0.55);
            box-shadow: 0 16px 40px rgba(79,70,229,0.25);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, rgba(79,70,229,1), rgba(79,70,229,0.75));
            }

        .btnx .arrow {
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(255,255,255,0.16);
            font-size: 12px;
            font-weight: 950;
        }

    .hint-line {
        margin-top: 12px;
        color: var(--muted2);
        font-weight: 850;
        font-size: 12px;
    }

    .hero-card {
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(0,0,0,0.30);
        padding: 14px;
        backdrop-filter: blur(10px);
    }

    .stat {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        padding: 12px;
        border-radius: 14px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.10);
        margin-bottom: 10px;
    }

        .stat:last-child {
            margin-bottom: 0;
        }

    .label {
        color: var(--muted2);
        font-weight: 900;
        font-size: 12px;
        letter-spacing: .2px;
    }

    .value {
        font-size: 16px;
        font-weight: 950;
    }

    .pill {
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 950;
        font-size: 12px;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.06);
        color: var(--text);
        white-space: nowrap;
    }

        .pill.accent {
            border-color: rgba(34,197,94,0.35);
            background: rgba(34,197,94,0.10);
        }

        .pill.blue {
            border-color: rgba(79,70,229,0.35);
            background: rgba(79,70,229,0.10);
        }

    /* BELOW HERO — FILL GAPS */
    .below {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 14px;
        align-items: stretch;
    }

    .panel {
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(0,0,0,0.22);
        box-shadow: 0 18px 60px rgba(0,0,0,0.20);
        padding: 16px;
    }

        .panel h2 {
            margin: 0 0 8px;
            font-size: 18px;
            font-weight: 950;
            letter-spacing: -0.2px;
        }

        .panel p {
            margin: 0 0 12px;
            color: var(--muted);
            line-height: 1.6;
            font-size: 14px;
        }

    .bullets {
        margin: 0;
        padding-left: 18px;
        color: var(--muted);
        line-height: 1.7;
        font-weight: 700;
        font-size: 14px;
    }

    .mini-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .mini {
        border-radius: 14px;
        padding: 12px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.06);
    }

        .mini .t {
            font-weight: 950;
            margin: 0 0 4px;
        }

        .mini .d {
            margin: 0;
            color: var(--muted);
            font-weight: 750;
            font-size: 13px;
            line-height: 1.55;
        }

    /* Compact “How it works” (no big scroll) */
    .how {
        margin-top: 14px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(0,0,0,0.22);
        padding: 14px 16px;
    }

    .how-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

    .how-title {
        margin: 0;
        font-size: 18px;
        font-weight: 950;
        letter-spacing: -0.2px;
    }

    .how-sub {
        margin: 0;
        color: var(--muted2);
        font-weight: 800;
        font-size: 12px;
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .step {
        border-radius: 14px;
        padding: 12px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.06);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: start;
        min-height: 70px;
    }

    .num {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 950;
        background: rgba(34,197,94,0.12);
        border: 1px solid rgba(34,197,94,0.22);
        color: #b7ffd7;
    }

    .st {
        margin: 0;
        font-weight: 950;
        font-size: 13px;
    }

    .sd {
        margin: 2px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 12.5px;
        line-height: 1.45;
    }

   @@media (max-width: 900px) {
        .hero-grid

    {
        grid-template-columns: 1fr;
    }

    .below {
        grid-template-columns: 1fr;
    }

    .steps {
        grid-template-columns: 1fr;
    }

    .hero h1 {
        font-size: 36px;
    }

    }
</style>

<div class="home-wrap">

    <section class="hero">
        <div class="hero-grid">
            <div>
                <div class="badge">
                    <span class="dot"></span>
                    Real-time neighborhood shortlisting for Kitchener–Waterloo
                </div>

                <h1>Pick priorities. Drop a pin. Get the best areas — fast.</h1>

                <p>
                    Shortlist helps students and renters in KW find neighborhoods that match what matters most —
                    using live map data to surface nearby places by priority.
                </p>

                <div class="cta-row">
                    <a class="btnx primary" href="/Filters/Index">
                        Start with Filters <span class="arrow">→</span>
                    </a>
                    <a class="btnx" href="/Results/Index">
                        View Results <span class="arrow">↗</span>
                    </a>
                    <a class="btnx" href="/SavedSearches/Index">
                        Saved <span class="arrow">★</span>
                    </a>
                </div>

                <div class="hint-line">
                    Tip: Filters → pick a location → Apply → see map markers → Save search.
                </div>
            </div>

            <div class="hero-card">
                <div class="stat">
                    <div>
                        <div class="label">Live Map</div>
                        <div class="value">OpenStreetMap + Leaflet</div>
                    </div>
                    <div class="pill blue">FREE</div>
                </div>
                <div class="stat">
                    <div>
                        <div class="label">Real-time Places</div>
                        <div class="value">Nearby matches by priority</div>
                    </div>
                    <div class="pill accent">LIVE</div>
                </div>
                <div class="stat">
                    <div>
                        <div class="label">Saved Searches</div>
                        <div class="value">Load / reuse in 1 click</div>
                    </div>
                    <div class="pill">PRO</div>
                </div>
            </div>
        </div>
    </section>

    <section class="below">
        <div class="panel">
            <h2>What the app does</h2>
            <p>Built for KW students: choose a location and instantly see what’s nearby.</p>
            <ul class="bullets">
                <li>Drop a pin and search within your radius (2–5 km typical).</li>
                <li>Pick up to 3 priorities (grocery, transit, parks, gym, parking, laundry).</li>
                <li>Get live map markers + save the setup for later.</li>
            </ul>
        </div>

        <div class="panel">
            <h2>Why it feels “real”</h2>
            <div class="mini-grid">
                <div class="mini">
                    <div class="t">⚡ Live data</div>
                    <p class="d">Results come from real OpenStreetMap queries.</p>
                </div>
                <div class="mini">
                    <div class="t">🗺️ Map-first UX</div>
                    <p class="d">Pick an area visually, not through long forms.</p>
                </div>
                <div class="mini">
                    <div class="t">💾 Saved searches</div>
                    <p class="d">One click reload for demos + real users.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="how">
        <div class="how-head">
            <h2 class="how-title">How it works</h2>
            <p class="how-sub">Fast, demo-friendly flow</p>
        </div>

        <div class="steps">
            <div class="step">
                <div class="num">1</div>
                <div>
                    <p class="st">Budget + distance</p>
                    <p class="sd">Shape your shortlist.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">2</div>
                <div>
                    <p class="st">Pick a map location</p>
                    <p class="sd">Drop a pin in KW.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">3</div>
                <div>
                    <p class="st">Choose priorities</p>
                    <p class="sd">Up to 3.</p>
                </div>
            </div>
            <div class="step">
                <div class="num">4</div>
                <div>
                    <p class="st">See results + save</p>
                    <p class="sd">Reuse anytime.</p>
                </div>
            </div>
        </div>
    </section>

</div>