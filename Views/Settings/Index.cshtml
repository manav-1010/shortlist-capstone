@model Shortlist.Web.Models.SettingsViewModel
@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg: #dbe4f3;
        --bg2: #d2ddf0;
        --bg3: #e2e8f6;
        --surface: rgba(255, 255, 255, 0.78);
        --surface-strong: rgba(255, 255, 255, 0.88);
        --surface-soft: rgba(246, 249, 255, 0.72);
        --surface-deep: rgba(232, 239, 250, 0.88);
        --surface-tint: rgba(224, 231, 255, 0.86);
        --border: rgba(100, 116, 139, 0.18);
        --border-strong: rgba(100, 116, 139, 0.28);
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: rgba(79, 70, 229, 0.14);
        --good: #15803d;
        --good-soft: rgba(21, 128, 61, 0.12);
        --danger: #b91c1c;
        --danger-soft: rgba(185, 28, 28, 0.10);
        --radius: 20px;
        --shadow-xl: 0 24px 70px rgba(15, 23, 42, 0.10);
        --shadow-lg: 0 18px 40px rgba(15, 23, 42, 0.08);
        --shadow-md: 0 10px 24px rgba(15, 23, 42, 0.06);
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    body {
        background: radial-gradient(1200px 700px at 0% -10%, rgba(79, 70, 229, 0.28), transparent 55%), radial-gradient(900px 600px at 100% 0%, rgba(37, 99, 235, 0.22), transparent 50%), radial-gradient(800px 500px at 50% 100%, rgba(14, 165, 233, 0.10), transparent 45%), linear-gradient(180deg, var(--bg) 0%, var(--bg2) 50%, var(--bg3) 100%);
    }

    .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 18px 16px 24px;
        color: var(--text);
    }

    .top {
        border: 1px solid var(--border);
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.16), transparent 58%), radial-gradient(560px 240px at 92% 18%, rgba(37,99,235,0.10), transparent 54%), linear-gradient(180deg, rgba(245, 248, 255, 0.80), rgba(233, 240, 250, 0.76));
        border-radius: 24px;
        padding: 18px;
        box-shadow: var(--shadow-lg);
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
        backdrop-filter: blur(14px);
    }

    h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 950;
        letter-spacing: -0.5px;
        color: var(--text);
    }

    .sub {
        margin-top: 8px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.5;
    }

    .toast {
        margin: 14px 0;
        border-radius: 16px;
        border: 1px solid rgba(21, 128, 61, 0.18);
        background: rgba(232, 247, 238, 0.86);
        color: var(--good);
        padding: 12px 14px;
        font-weight: 900;
        box-shadow: var(--shadow-md);
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: 14px;
    }

    .card {
        border: 1px solid var(--border);
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.80), rgba(232, 239, 250, 0.76));
        padding: 16px;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(12px);
    }

    .k {
        color: var(--muted2);
        font-weight: 850;
        font-size: 12px;
    }

    .v {
        font-weight: 950;
        margin-top: 4px;
        color: var(--text);
    }

    .row {
        margin-top: 12px;
        display: grid;
        gap: 8px;
    }

    .inputx {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 10px 12px;
        font-weight: 850;
        outline: none;
        width: 100%;
        box-shadow: var(--shadow-md);
    }

        .inputx::placeholder {
            color: var(--muted2);
            font-weight: 750;
        }

        .inputx:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
        }

    .btnx {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 10px 12px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,0.92);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

        .btnx.danger {
            background: rgba(254, 242, 242, 0.82);
            border-color: rgba(185, 28, 28, 0.18);
            color: var(--danger);
        }

            .btnx.danger:hover {
                background: rgba(254, 226, 226, 0.92);
                border-color: rgba(185, 28, 28, 0.24);
            }

    .btnRow {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .badge {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        font-weight: 850;
        font-size: 12px;
        margin-left: 10px;
        color: var(--accent);
        box-shadow: var(--shadow-md);
    }

    .note {
        margin-top: 10px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.55;
    }

    .judge-list {
        margin: 10px 0 0;
        padding-left: 18px;
        color: var(--muted);
        font-weight: 750;
        line-height: 1.75;
        font-size: 13px;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="wrap">
    <div class="top">
        <div>
            <h1>Settings</h1>
            <div class="sub">Real product controls: preferences, privacy, and data actions.</div>
        </div>
        <div class="k">Signed in as <span class="badge">@Model.AuthProvider</span></div>
    </div>

    @if (TempData["Toast"] != null)
    {
        <div class="toast">@TempData["Toast"]</div>
    }

    <div class="grid">

        <div class="card">
            <div class="k">Account</div>
            <div class="row">
                <div class="k">Email</div>
                <div class="v">@Model.Email</div>
            </div>
            <div class="row">
                <div class="k">Provider</div>
                <div class="v">@Model.AuthProvider</div>
            </div>
            <div class="btnRow">
                <a class="btnx" asp-controller="SavedSearches" asp-action="Index">Saved Searches</a>
                <a class="btnx" asp-controller="Compare" asp-action="Index">Compare</a>
            </div>
        </div>

        <div class="card">
            <div class="k">Search Preferences</div>

            <form method="post" asp-action="Save">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="k">Default Radius (km)</div>
                    <input class="inputx" type="number" name="DefaultRadiusKm" min="1" max="25" value="@Model.DefaultRadiusKm" />
                </div>

                <div class="row">
                    <div class="k">Default Priorities (comma-separated, max 3)</div>
                    <input class="inputx" name="DefaultPriorities" value="@Model.DefaultPriorities" placeholder="grocery, transit, parks" />
                </div>

                <div class="row">
                    <div class="k">Default Location Label (optional)</div>
                    <input class="inputx" name="DefaultLocationLabel" value="@Model.DefaultLocationLabel" placeholder="Waterloo, ON" />
                </div>

                <div class="btnRow">
                    <button class="btnx primary" type="submit">Save Settings</button>
                </div>
            </form>
        </div>

        <div class="card">
            <div class="k">Data & Privacy (Demo actions)</div>
            <div class="note">These actions help with demos and testing edge cases.</div>

            <div class="btnRow">
                <form method="post" asp-action="ClearSession" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button class="btnx" type="submit">Clear Session Filters</button>
                </form>

                <form method="post" asp-action="ClearCompare" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button class="btnx" type="submit">Clear Compare List</button>
                </form>
            </div>

            <div class="btnRow" style="margin-top:12px;">
                <form method="post" asp-action="DeleteAllSaved" style="margin:0;" onsubmit="return confirm('Delete ALL saved searches?');">
                    @Html.AntiForgeryToken()
                    <button class="btnx danger" type="submit">Delete All Saved Searches</button>
                </form>

                <a class="btnx danger" asp-controller="Account" asp-action="Logout" onclick="return confirm('Logout now?');">Logout</a>
            </div>
        </div>

        <div class="card">
            <div class="k">Legal & About</div>
            <div class="note">
                Privacy policy, terms, and credits.
            </div>

            <div class="btnRow">
                <a class="btnx" asp-controller="Settings" asp-action="Legal">
                    View Privacy & Legal
                </a>
            </div>

            <div class="note" style="margin-top:12px;">
                Map data © OpenStreetMap contributors. UI built for demo and portfolio.
            </div>
        </div>

    </div>
</div>