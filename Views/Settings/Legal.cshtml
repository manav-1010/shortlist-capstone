@{
    Layout = "_Layout";
    ViewData["Title"] = "Privacy & Legal";
}

<style>
    :root {
        --bg: #f5f7fb;
        --bg2: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --surface-tint: #eef2ff;
        --border: #dbe3ee;
        --border-strong: #cbd5e1;
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --radius: 20px;
        --shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
        --shadow2: 0 10px 24px rgba(15, 23, 42, 0.06);
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    body {
        background: radial-gradient(1000px 500px at 10% -5%, rgba(79,70,229,0.10), transparent 60%), radial-gradient(900px 460px at 100% 0%, rgba(34,197,94,0.08), transparent 58%), linear-gradient(180deg, var(--bg), var(--bg2));
    }

    .wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 18px 16px 28px;
        color: var(--text);
    }

    .top {
        border: 1px solid var(--border);
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.08), transparent 60%), radial-gradient(560px 240px at 92% 18%, rgba(34,197,94,0.07), transparent 55%), linear-gradient(180deg, #ffffff, #f8fbff);
        border-radius: var(--radius);
        padding: 18px;
        box-shadow: var(--shadow2);
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    h1 {
        margin: 0;
        font-size: 26px;
        font-weight: 950;
        letter-spacing: -0.4px;
        color: var(--text);
    }

    .sub {
        margin-top: 8px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.55;
        max-width: 62ch;
    }

    .card {
        margin-top: 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: linear-gradient(180deg, #ffffff, #fbfdff);
        padding: 16px;
        box-shadow: var(--shadow2);
    }

    .h {
        font-weight: 950;
        margin: 0 0 8px;
        font-size: 14px;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .p {
        margin: 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.7;
    }

    .list {
        margin: 10px 0 0;
        padding-left: 18px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.8;
    }

    .btnRow {
        margin-top: 12px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btnx {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 10px 12px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: var(--shadow2);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: var(--border-strong);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: var(--accent);
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
                border-color: var(--accent-hover);
            }

    .small {
        margin-top: 10px;
        color: var(--muted2);
        font-weight: 750;
        font-size: 12px;
        line-height: 1.65;
    }
</style>

<div class="wrap">
    <div class="top">
        <div>
            <h1>Privacy & Legal</h1>
            <div class="sub">
                Privacy, terms, and credits for the Shortlist app.
            </div>
        </div>

        <div class="btnRow" style="margin-top:0;">
            <a class="btnx" asp-controller="Settings" asp-action="Index">Back to Settings</a>
            <a class="btnx primary" asp-controller="Filters" asp-action="Index">Back to Filters</a>
        </div>
    </div>

    <div class="card">
        <div class="h">Privacy Policy</div>
        <p class="p">
            Shortlist is an application built for portfolio and judging purposes. It stores only the minimum information required to support features such as saved searches and user preferences.
        </p>
        <ul class="list">
            <li><b>Account data:</b> email and authentication provider.</li>
            <li><b>Preferences:</b> default radius, priorities, and optional location label.</li>
            <li><b>Saved searches:</b> stored only for your account so you can reuse them later.</li>
            <li><b>Location:</b> map pin coordinates are used to run search queries and are not shared publicly.</li>
        </ul>
        <div class="small">
            You can clear temporary session data and delete saved searches from the Settings page.
        </div>
    </div>

    <div class="card">
        <div class="h">Terms of Use</div>
        <p class="p">
            This application is provided “as-is” for demonstration purposes. Results depend on live map data and may change over time. It should not be used as a substitute for legal, safety, or official housing advice.
        </p>
        <ul class="list">
            <li>Data is shown for convenience only and may be incomplete or outdated.</li>
            <li>You are responsible for verifying housing and neighborhood details from official sources.</li>
            <li>Abuse or excessive automated requests may be rate-limited.</li>
        </ul>
    </div>

    <div class="card">
        <div class="h">Credits</div>
        <p class="p">
            Map tiles and geographic data are powered by OpenStreetMap and displayed using Leaflet.
        </p>
        <ul class="list">
            <li>© OpenStreetMap contributors</li>
            <li>Leaflet (interactive maps)</li>
        </ul>
    </div>
</div>