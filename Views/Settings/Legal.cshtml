@{
    Layout = "_Layout";
    ViewData["Title"] = "Privacy & Legal";
}

<style>
    :root {
        --text: rgba(255,255,255,0.92);
        --muted: rgba(255,255,255,0.70);
        --border: rgba(255,255,255,0.12);
        --radius: 20px;
        --shadow: 0 18px 60px rgba(0,0,0,0.35);
    }

    body {
        background: radial-gradient(900px 380px at 15% 0%, rgba(79,70,229,0.25), transparent 60%), radial-gradient(700px 320px at 90% 30%, rgba(34,197,94,0.18), transparent 55%), linear-gradient(180deg, #07080c, #0b0d12 45%, #0b0d12);
    }

    .wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 18px 16px 28px;
        color: var(--text);
    }

    .top {
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.05);
        border-radius: var(--radius);
        padding: 16px;
        box-shadow: var(--shadow);
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    h1 {
        margin: 0;
        font-size: 26px;
        font-weight: 950;
        letter-spacing: -0.4px;
    }

    .sub {
        margin-top: 8px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.45;
    }

    .card {
        margin-top: 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: rgba(0,0,0,0.20);
        padding: 16px;
        box-shadow: var(--shadow);
    }

    .h {
        font-weight: 950;
        margin: 0 0 8px;
        font-size: 14px;
        letter-spacing: -0.2px;
    }

    .p {
        margin: 0;
        color: rgba(255,255,255,0.80);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.65;
    }

    .list {
        margin: 10px 0 0;
        padding-left: 18px;
        color: rgba(255,255,255,0.80);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.7;
    }

    .btnRow {
        margin-top: 12px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btnx {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.06);
        color: var(--text);
        padding: 10px 12px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btnx.primary {
            background: linear-gradient(135deg, rgba(79,70,229,0.95), rgba(79,70,229,0.62));
            border-color: rgba(79,70,229,0.55);
        }

    .small {
        margin-top: 10px;
        color: rgba(255,255,255,0.62);
        font-weight: 750;
        font-size: 12px;
        line-height: 1.6;
    }
</style>

<div class="wrap">
    <div class="top">
        <div>
            <h1>Privacy & Legal</h1>
            <div class="sub">
               
            </div>
        </div>

        <div class="btnRow" style="margin-top:0;">
            <a class="btnx" asp-controller="Settings" asp-action="Index">Back to Settings</a>
            <a class="btnx primary" asp-controller="Filters" asp-action="Index">Back to Filters</a>
        </div>
    </div>

    <div class="card">
        <div class="h">Privacy Policy (Demo)</div>
        <p class="p">
            Shortlist is a demo application built for portfolio/judging purposes. It stores minimal information needed to provide
            features like saved searches and preferences.
        </p>
        <ul class="list">
            <li><b>Account data:</b> email + authentication provider.</li>
            <li><b>Preferences:</b> default radius, priorities, and optional location label.</li>
            <li><b>Saved searches:</b> stored only for your account so you can reuse them.</li>
            <li><b>Location:</b> map pin coordinates are used to run search queries and are not shared publicly.</li>
        </ul>
        <div class="small">
        </div>
    </div>

    <div class="card">
        <div class="h">Terms of Use </div>
        <p class="p">
            This application is provided “as-is” for demonstration purposes. Results depend on live map data and may change over time.
            Do not rely on this app for safety or legal decisions.
        </p>
        <ul class="list">
            <li>Data is shown for convenience only and may be incomplete or outdated.</li>
            <li>You are responsible for verifying housing/neighborhood details from official sources.</li>
            <li>Abuse or excessive automated requests may be rate-limited.</li>
        </ul>
    </div>

    <div class="card">
        <div class="h">Credits</div>
        <p class="p">
            Map tiles and geographic data are powered by OpenStreetMap and displayed using Leaflet.
        </p>
        <ul class="list">
            <li>© OpenStreetMap contributors</li>
            <li>Leaflet (interactive maps)</li>
        </ul>
    </div>
</div>