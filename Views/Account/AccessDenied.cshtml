@{
    Layout = "_Layout";
    ViewData["Title"] = "Access Denied";
}

<div style="max-width: 500px; margin: 50px auto; text-align: center;">
    <h1>Login Cancelled</h1>
    <p>You cancelled the login process or access was denied.</p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Try Again</a>
</div>