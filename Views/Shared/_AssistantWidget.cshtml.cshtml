@{
    var currentPath = Context.Request.Path.Value ?? "";
}

<style>
    .assistant-fab {
        position: fixed;
        right: 22px;
        bottom: 22px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: 0;
        background: linear-gradient(135deg, var(--accent), #6366f1);
        color: #fff;
        font-size: 24px;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 18px 40px rgba(79, 70, 229, 0.28);
        z-index: 1200;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform .12s ease, box-shadow .12s ease;
    }

    .assistant-fab:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 44px rgba(79, 70, 229, 0.34);
    }

    .assistant-panel {
        position: fixed;
        right: 22px;
        bottom: 94px;
        width: 380px;
        max-width: calc(100vw - 28px);
        height: 560px;
        max-height: calc(100vh - 130px);
        border-radius: 24px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        box-shadow: var(--shadow-lg);
        z-index: 1200;
        display: none;
        flex-direction: column;
        overflow: hidden;
        backdrop-filter: blur(14px);
    }

    .assistant-panel.open {
        display: flex;
    }

    .assistant-head {
        padding: 16px 18px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background: linear-gradient(135deg, rgba(79,70,229,0.10), var(--surface-strong));
    }

    .assistant-title-wrap {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .assistant-title {
        margin: 0;
        font-size: 18px;
        font-weight: 950;
        color: var(--text);
    }

    .assistant-sub {
        color: var(--muted);
        font-size: 12px;
        font-weight: 750;
    }

    .assistant-close {
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        width: 38px;
        height: 38px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 900;
        box-shadow: var(--shadow-md);
    }

    .assistant-body {
        flex: 1;
        overflow: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .assistant-msg {
        max-width: 88%;
        padding: 12px 14px;
        border-radius: 16px;
        line-height: 1.6;
        font-size: 14px;
        font-weight: 750;
        box-shadow: var(--shadow-md);
        word-break: break-word;
    }

    .assistant-msg.bot {
        align-self: flex-start;
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
    }

    .assistant-msg.user {
        align-self: flex-end;
        background: linear-gradient(135deg, var(--accent), #6366f1);
        color: #fff;
        border: 1px solid transparent;
    }

    .assistant-quick {
        padding: 0 16px 12px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .assistant-chip {
        border: 1px solid rgba(79,70,229,0.16);
        background: var(--surface-tint);
        color: var(--accent);
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 850;
        font-size: 12px;
        cursor: pointer;
    }

    .assistant-foot {
        border-top: 1px solid var(--border);
        padding: 14px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        background: var(--surface-strong);
    }

    .assistant-input {
        width: 100%;
        border-radius: 14px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 12px 14px;
        font-size: 14px;
        font-weight: 750;
        outline: none;
        box-shadow: var(--shadow-md);
    }

    .assistant-input:focus {
        border-color: var(--accent);
        box-shadow: var(--focus);
    }

    .assistant-send {
        border: 0;
        border-radius: 14px;
        padding: 0 16px;
        min-width: 92px;
        font-weight: 900;
        color: #fff;
        cursor: pointer;
        background: linear-gradient(135deg, var(--accent), #6366f1);
        box-shadow: var(--shadow-md);
    }

    @@media (max-width: 640px) {
        .assistant-panel {
            right: 12px;
            left: 12px;
            width: auto;
            bottom: 84px;
            height: 70vh;
        }

        .assistant-fab {
            right: 16px;
            bottom: 16px;
        }
    }
</style>

<button id="assistantFab" class="assistant-fab" type="button" aria-label="Open Shortlist Assistant">
    💬
</button>

<div id="assistantPanel" class="assistant-panel" aria-hidden="true">
    <div class="assistant-head">
        <div class="assistant-title-wrap">
            <div class="assistant-title">Shortlist Assistant</div>
            <div class="assistant-sub">Ask about filters, results, premium, reports, and more.</div>
        </div>
        <button id="assistantClose" class="assistant-close" type="button" aria-label="Close assistant">✕</button>
    </div>

    <div id="assistantBody" class="assistant-body">
        <div class="assistant-msg bot">
            Hi! I’m the Shortlist Assistant. Ask me anything about filters, results, premium, reports, compare, listings, or how to use the app.
        </div>
    </div>

    <div class="assistant-quick">
        <button type="button" class="assistant-chip" data-prompt="How do filters work?">Filters Help</button>
        <button type="button" class="assistant-chip" data-prompt="Explain results score">Explain Results</button>
        <button type="button" class="assistant-chip" data-prompt="What does premium include?">Premium Help</button>
        <button type="button" class="assistant-chip" data-prompt="How do I compare places?">Compare Help</button>
        <button type="button" class="assistant-chip" data-prompt="How do I use the AI report?">AI Report</button>
    </div>

    <form id="assistantForm" class="assistant-foot">
        <input id="assistantInput" class="assistant-input" type="text" placeholder="Ask Shortlist Assistant..." />
        <button class="assistant-send" type="submit">Send</button>
    </form>
</div>

<script>
    (function () {
        const fab = document.getElementById("assistantFab");
        const panel = document.getElementById("assistantPanel");
        const closeBtn = document.getElementById("assistantClose");
        const body = document.getElementById("assistantBody");
        const form = document.getElementById("assistantForm");
        const input = document.getElementById("assistantInput");
        const chips = document.querySelectorAll(".assistant-chip");
        const currentPage = "@currentPath".toLowerCase();

        const storageKey = "shortlist-assistant-open";

        function appendMessage(text, type) {
            const div = document.createElement("div");
            div.className = `assistant-msg ${type}`;
            div.textContent = text;
            body.appendChild(div);
            body.scrollTop = body.scrollHeight;
        }

        function setOpen(isOpen) {
            panel.classList.toggle("open", isOpen);
            panel.setAttribute("aria-hidden", isOpen ? "false" : "true");
            localStorage.setItem(storageKey, isOpen ? "1" : "0");
            if (isOpen) {
                setTimeout(() => input?.focus(), 80);
            }
        }

        async function askAssistant(message) {
            appendMessage(message, "user");

            try {
                const res = await fetch("/api/assistant/ask", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        message: message,
                        currentPage: currentPage
                    })
                });

                if (!res.ok) {
                    appendMessage("Sorry, I couldn’t respond right now. Please try again.", "bot");
                    return;
                }

                const data = await res.json();
                appendMessage(data.reply || "Sorry, I couldn’t find an answer.", "bot");
            } catch {
                appendMessage("Sorry, I couldn’t respond right now. Please try again.", "bot");
            }
        }

        fab?.addEventListener("click", () => setOpen(true));
        closeBtn?.addEventListener("click", () => setOpen(false));

        form?.addEventListener("submit", async function (e) {
            e.preventDefault();
            const msg = (input.value || "").trim();
            if (!msg) return;
            input.value = "";
            await askAssistant(msg);
        });

        chips.forEach(chip => {
            chip.addEventListener("click", async () => {
                const prompt = chip.getAttribute("data-prompt");
                if (!prompt) return;
                setOpen(true);
                await askAssistant(prompt);
            });
        });

        const savedState = localStorage.getItem(storageKey);
        if (savedState === "1") {
            setOpen(true);
        }
    })();
</script>