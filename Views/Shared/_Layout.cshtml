<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Shortlist</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="topbar">
        <div class="brand">Shortlist</div>
        <nav class="nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Filters" asp-action="Index">Filters</a>
            <a asp-controller="Results" asp-action="Index">Results</a>
        </nav>
    </header>

    <div class="page">
        @await Html.PartialAsync("_HeaderSummary")
        <main class="content">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js"></script>
</body>
</html>
