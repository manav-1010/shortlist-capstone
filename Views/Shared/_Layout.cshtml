<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shortlist</title>

    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        .topbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 18px;
            background: linear-gradient(180deg, #0b0d12, #0b0d12);
            border-bottom: 1px solid rgba(255,255,255,0.10);
        }

        .brand {
            color: rgba(255,255,255,0.92);
            font-weight: 950;
            letter-spacing: -0.3px;
            font-size: 18px;
        }

        .nav {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .nav a {
                color: rgba(255,255,255,0.88);
                text-decoration: none;
                padding: 8px 10px;
                border-radius: 10px;
                font-weight: 850;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

                .nav a:hover {
                    background: rgba(255,255,255,0.08);
                    color: rgba(255,255,255,0.96);
                }

        .nav-btn {
            border: 1px solid rgba(255,255,255,0.18);
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.92);
            padding: 8px 12px;
            border-radius: 10px;
            font-weight: 900;
            cursor: pointer;
        }

            .nav-btn:hover {
                background: rgba(255,255,255,0.12);
            }

        .icon-only {
            width: 38px;
            height: 38px;
            justify-content: center;
            padding: 0;
            border: 1px solid rgba(255,255,255,0.14);
            background: rgba(255,255,255,0.06);
            border-radius: 12px;
        }

            .icon-only:hover {
                background: rgba(255,255,255,0.10);
                border-color: rgba(255,255,255,0.22);
            }

            .icon-only svg {
                width: 18px;
                height: 18px;
                fill: rgba(255,255,255,0.90);
            }

        .page {
            max-width: 1200px;
            margin: 0 auto;
        }

        .content {
            padding: 14px 16px 40px;
        }

        .filter-summary {
            padding: 10px 16px;
            font-weight: 800;
            color: rgba(255,255,255,0.80);
            background: rgba(0,0,0,0.35);
            border-bottom: 1px solid rgba(255,255,255,0.10);
        }

        .summary-item {
            margin-right: 8px;
        }

        .summary-separator {
            margin: 0 8px;
            opacity: 0.55;
        }

        .footer {
            margin-top: 18px;
            padding: 14px 16px 20px;
            color: rgba(255,255,255,0.55);
            font-weight: 750;
            font-size: 12px;
            border-top: 1px solid rgba(255,255,255,0.10);
        }

            .footer a {
                color: rgba(255,255,255,0.70);
                text-decoration: none;
            }

                .footer a:hover {
                    color: rgba(255,255,255,0.88);
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <header class="topbar">
        <div class="brand">Shortlist</div>

        <nav class="nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Filters" asp-action="Index">Filters</a>
            <a asp-controller="Results" asp-action="Index">Results</a>

            <a asp-controller="Housing" asp-action="Index">Housing Providers</a>
            <a asp-controller="TenantChecklist" asp-action="Index">Tenant Checklist</a>
            <a asp-controller="Compare" asp-action="Index">Compare</a>

            <!-- Settings icon -->
            <a asp-controller="Settings" asp-action="Index" class="icon-only" aria-label="Settings" title="Settings">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M19.14,12.94a7.43,7.43,0,0,0,.05-.94,7.43,7.43,0,0,0-.05-.94l2.11-1.65a.5.5,0,0,0,.12-.64l-2-3.46a.5.5,0,0,0-.6-.22l-2.49,1a7.28,7.28,0,0,0-1.63-.94l-.38-2.65A.5.5,0,0,0,13.8,2H10.2a.5.5,0,0,0-.49.42L9.33,5.07a7.28,7.28,0,0,0-1.63.94l-2.49-1a.5.5,0,0,0-.6.22l-2,3.46a.5.5,0,0,0,.12.64L4.86,11.06a7.43,7.43,0,0,0-.05.94,7.43,7.43,0,0,0,.05.94L2.75,14.59a.5.5,0,0,0-.12.64l2,3.46a.5.5,0,0,0,.6.22l2.49-1a7.28,7.28,0,0,0,1.63.94l.38,2.65a.5.5,0,0,0,.49.42h3.6a.5.5,0,0,0,.49-.42l.38-2.65a7.28,7.28,0,0,0,1.63-.94l2.49,1a.5.5,0,0,0,.6-.22l2-3.46a.5.5,0,0,0-.12-.64ZM12,15.5A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
                </svg>
            </a>

            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="SavedSearches" asp-action="Index">Saved</a>

                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    <button type="submit" class="nav-btn">Logout</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login">Login</a>
            }
        </nav>
    </header>

    <div class="page">
        @await Html.PartialAsync("_HeaderSummary")

        <main class="content">
            @RenderBody()
        </main>
        <footer class="footer">
            © @DateTime.Now.Year Shortlist. All rights reserved.
            <span style="opacity:.6">•</span>
            Map data © OpenStreetMap contributors.
        </footer>
    </div>

    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>