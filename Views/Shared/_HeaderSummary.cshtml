@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Shortlist.Web.Models

@{
    // Show summary only on pages where it adds value
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var show = controller == "Filters" || controller == "Results" || controller == "SavedSearches";

    // 1) Try "FilterState" JSON first
    FilterState? state = null;
    var json = Context.Session.GetString("FilterState");

    if (!string.IsNullOrWhiteSpace(json))
    {
        try
        {
            state = JsonSerializer.Deserialize<FilterState>(json);
        }
        catch
        {
            state = null;
        }
    }

    // 2) Fallback to separate session keys
    int? budget = null;
    if (state?.Budget.HasValue == true)
    {
        budget = (int)Math.Round(state.Budget.Value);
    }
    else
    {
        budget = Context.Session.GetInt32("Budget");
    }

    int? distance = null;
    if (state?.MaxDistanceKm.HasValue == true)
    {
        distance = state.MaxDistanceKm.Value;
    }
    else
    {
        distance = Context.Session.GetInt32("Distance");
    }

    string? priorities = null;
    if (state?.Priorities != null && state.Priorities.Count > 0)
    {
        priorities = string.Join(", ", state.Priorities);
    }
    else
    {
        priorities = Context.Session.GetString("Priorities");
    }

    var hasAny = budget.HasValue || distance.HasValue || !string.IsNullOrWhiteSpace(priorities);
}

@if (show && hasAny)
{
    <div class="filter-summary">
        <span class="summary-item">
            Budget: @(budget.HasValue ? $"${budget}" : "Any")
        </span>

        <span class="summary-separator">|</span>

        <span class="summary-item">
            Distance: @(distance.HasValue ? $"{distance} km or less" : "Any")
        </span>

        @if (!string.IsNullOrWhiteSpace(priorities))
        {
            <span class="summary-separator">|</span>

            <span class="summary-item">
                Priorities: @priorities
            </span>
        }
    </div>
}