@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Shortlist.Web.Models

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var show = controller == "Filters" || controller == "Results" || controller == "SavedSearches";

    FilterState? state = null;

    if (ViewData["HeaderFilters"] is FilterState vdFilters)
    {
        state = vdFilters;
    }
    else
    {
        var json = Context.Session.GetString("FilterState");

        if (!string.IsNullOrWhiteSpace(json))
        {
            try
            {
                state = JsonSerializer.Deserialize<FilterState>(json);
            }
            catch
            {
                state = null;
            }
        }
    }

    int? budget = null;
    if (state?.Budget.HasValue == true)
    {
        budget = (int)Math.Round(state.Budget.Value);
    }
    else
    {
        budget = Context.Session.GetInt32("Budget");
    }

    int? distance = null;
    if (state?.MaxDistanceKm.HasValue == true)
    {
        distance = state.MaxDistanceKm.Value;
    }
    else
    {
        distance = Context.Session.GetInt32("Distance");
    }

    int? radius = null;
    if (state != null && state.RadiusKm > 0)
    {
        radius = state.RadiusKm;
    }

    string? priorities = null;
    if (state?.Priorities != null && state.Priorities.Count > 0)
    {
        priorities = string.Join(", ", state.Priorities);
    }
    else
    {
        priorities = Context.Session.GetString("Priorities");
    }

    string? locationLabel = null;
    if (!string.IsNullOrWhiteSpace(state?.LocationLabel))
    {
        locationLabel = state.LocationLabel;
    }

    bool hasCoords = state?.Lat.HasValue == true && state?.Lng.HasValue == true;

    var hasAny =
        budget.HasValue ||
        distance.HasValue ||
        radius.HasValue ||
        !string.IsNullOrWhiteSpace(priorities) ||
        !string.IsNullOrWhiteSpace(locationLabel) ||
        hasCoords;
}

@if (show && hasAny)
{
    <div class="filter-summary">
        <span class="summary-item">
            Budget: @(budget.HasValue ? $"${budget}" : "Any")
        </span>

        <span class="summary-separator">|</span>

        <span class="summary-item">
            Max Distance: @(distance.HasValue ? $"{distance} km or less" : "Any")
        </span>

        @if (radius.HasValue)
        {
            <span class="summary-separator">|</span>

            <span class="summary-item">
                Radius: @radius km
            </span>
        }

        @if (!string.IsNullOrWhiteSpace(locationLabel))
        {
            <span class="summary-separator">|</span>

            <span class="summary-item">
                Location: @locationLabel
            </span>
        }

        @if (!string.IsNullOrWhiteSpace(priorities))
        {
            <span class="summary-separator">|</span>

            <span class="summary-item">
                Priorities: @priorities
            </span>
        }

        @if (hasCoords)
        {
            <span class="summary-separator">|</span>

            <span class="summary-item">
                Pin: @state!.Lat!.Value.ToString("0.0000"), @state.Lng!.Value.ToString("0.0000")
            </span>
        }
    </div>
}