@{
    Layout = "_Layout";
    ViewData["Title"] = "Rental Listings";

    var query = ViewBag.Query as string ?? "";
    var city = ViewBag.City as string ?? "Kitchener";
    var province = ViewBag.Province as string ?? "ON";
    var beds = ViewBag.Beds ?? 0;
    var maxPrice = ViewBag.MaxPrice ?? "";
}

<style>
    .listings-shell {
        max-width: 1280px;
        margin: 0 auto;
        padding: 18px 16px 30px;
        color: var(--text);
    }

    .listings-hero {
        border-radius: 26px;
        border: 1px solid var(--border);
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.16), transparent 58%), radial-gradient(560px 240px at 92% 18%, rgba(37,99,235,0.10), transparent 54%), linear-gradient(180deg, var(--surface-strong), var(--surface));
        box-shadow: var(--shadow-lg);
        padding: 22px;
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 18px;
        align-items: start;
    }

    .hero-title {
        margin: 0;
        font-size: 32px;
        line-height: 1.05;
        font-weight: 950;
        color: var(--text);
        letter-spacing: -0.8px;
    }

    .hero-sub {
        margin-top: 12px;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.75;
        max-width: 58ch;
        font-weight: 750;
    }

    .hero-pills {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid rgba(79, 70, 229, 0.18);
        background: var(--surface-tint);
        color: var(--accent);
        font-weight: 850;
        font-size: 12px;
        box-shadow: var(--shadow-md);
    }

    .search-panel {
        border: 1px solid var(--border);
        border-radius: 22px;
        background: var(--surface);
        box-shadow: var(--shadow-md);
        padding: 16px;
        display: grid;
        gap: 12px;
    }

    .search-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .field {
        display: grid;
        gap: 6px;
    }

        .field label {
            color: var(--muted2);
            font-size: 12px;
            font-weight: 850;
        }

    .inputx {
        width: 100%;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 11px 12px;
        font-weight: 850;
        outline: none;
        box-shadow: var(--shadow-md);
    }

        .inputx::placeholder {
            color: var(--muted2);
            font-weight: 750;
        }

        .inputx:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
        }

    .btn-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btnx {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 11px 14px;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
        white-space: nowrap;
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
        }

    .status-row {
        margin-top: 16px;
        display: grid;
        gap: 12px;
    }

    .error-box {
        display: none;
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid rgba(185, 28, 28, 0.18);
        background: rgba(254, 242, 242, 0.92);
        color: #b42318;
        font-weight: 850;
        box-shadow: var(--shadow-md);
    }

    .status-box {
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--muted);
        font-weight: 850;
        box-shadow: var(--shadow-md);
    }

    .listings-grid {
        margin-top: 18px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .listing-card {
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        box-shadow: var(--shadow-md);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .listing-photo {
        height: 220px;
        background: linear-gradient(180deg, #eef2ff, #e2e8f0);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .listing-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .no-photo {
        color: var(--muted2);
        font-weight: 850;
    }

    .listing-body {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .listing-price {
        font-size: 24px;
        font-weight: 950;
        color: var(--text);
    }

    .listing-title {
        font-size: 15px;
        font-weight: 900;
        line-height: 1.55;
        color: var(--text);
    }

    .listing-sub {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.55;
        font-weight: 750;
    }

    .chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .chip {
        padding: 7px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--accent);
        font-size: 12px;
        font-weight: 850;
        box-shadow: var(--shadow-md);
    }

    .listing-actions {
        margin-top: auto;
        padding-top: 8px;
    }

    @@media (max-width: 1100px) {
        .listings-hero {
            grid-template-columns: 1fr;
        }

        .search-grid {
            grid-template-columns: 1fr 1fr;
        }

        .listings-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 700px) {
        .search-grid {
            grid-template-columns: 1fr;
        }

        .listings-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="listings-shell">
    <section class="listings-hero">
        <div>
            <h1 class="hero-title">Rental Listings</h1>
            <div class="hero-sub">
                Browse rental-style listings inside your app. Search by city or custom query, review photos, compare price and beds quickly, and open the original detail page only when needed.
            </div>

            <div class="hero-pills">
                <span class="hero-pill">RapidAPI-powered</span>
                <span class="hero-pill">Photos + details</span>
                <span class="hero-pill">Portfolio-ready UX</span>
            </div>
        </div>

        <form id="listingSearchForm" class="search-panel">
            <div class="search-grid">
                <div class="field">
                    <label for="query">Search</label>
                    <input id="query" class="inputx" placeholder="e.g. Victoria Park" value="@query" />
                </div>

                <div class="field">
                    <label for="city">City</label>
                    <input id="city" class="inputx" placeholder="Kitchener" value="@city" />
                </div>

                <div class="field">
                    <label for="province">Province</label>
                    <input id="province" class="inputx" placeholder="ON" value="@province" />
                </div>

                <div class="field">
                    <label for="beds">Min Beds</label>
                    <input id="beds" class="inputx" type="number" min="0" placeholder="0" value="@beds" />
                </div>

                <div class="field">
                    <label for="maxPrice">Max Price</label>
                    <input id="maxPrice" class="inputx" type="number" min="0" placeholder="2000" value="@maxPrice" />
                </div>
            </div>

            <div class="btn-row">
                <button class="btnx primary" type="submit">Search Listings</button>
                <a class="btnx" href="/Results">Back to Results</a>
                <a class="btnx" href="/Housing">Housing Providers</a>
            </div>
        </form>
    </section>

    <div class="status-row">
        <div id="listingError" class="error-box"></div>
        <div id="listingStatus" class="status-box">Search for a city or area to load rental listings.</div>
    </div>

    <div id="listingGrid" class="listings-grid"></div>
</div>

<script>
    const form = document.getElementById("listingSearchForm");
    const listingGrid = document.getElementById("listingGrid");
    const listingError = document.getElementById("listingError");
    const listingStatus = document.getElementById("listingStatus");

    function showError(msg) {
        listingError.style.display = "block";
        listingError.textContent = msg;
    }

    function clearError() {
        listingError.style.display = "none";
        listingError.textContent = "";
    }

    function renderListings(items) {
        listingGrid.innerHTML = "";

        if (!Array.isArray(items) || items.length === 0) {
            listingStatus.textContent = "No listings found for this search.";
            return;
        }

        listingStatus.textContent = `${items.length} listing(s) found.`;

        items.forEach(item => {
            const image = item.image || "";
            const price = item.price || "Price not listed";
            const beds = item.beds ?? "—";
            const baths = item.baths ?? "—";
            const address = item.address || "Address unavailable";
            const city = item.city || "";
            const province = item.province || "";
            const link = item.detailUrl || "";
            const type = item.propertyType || "Rental";

            const card = document.createElement("div");
            card.className = "listing-card";

            card.innerHTML = `
                <div class="listing-photo">
                    ${image
                        ? `<img src="${image}" alt="Listing photo" loading="lazy">`
                        : `<div class="no-photo">No image available</div>`}
                </div>

                <div class="listing-body">
                    <div class="listing-price">${price}</div>

                    <div class="listing-title">${address}</div>

                    <div class="listing-sub">
                        ${city}${city && province ? ", " : ""}${province}
                    </div>

                    <div class="chips">
                        <span class="chip">${type}</span>
                        <span class="chip">Beds: ${beds}</span>
                        <span class="chip">Baths: ${baths}</span>
                    </div>

                    <div class="listing-actions">
                        ${link
                            ? `<a class="btnx" href="${link}" target="_blank" rel="noopener noreferrer">Open Detail ↗</a>`
                            : `<span class="listing-sub">No detail link available</span>`
                        }
                    </div>
                </div>
            `;

            listingGrid.appendChild(card);
        });
    }

    async function loadListings() {
        clearError();
        listingGrid.innerHTML = "";
        listingStatus.textContent = "Loading listings...";

        const query = document.getElementById("query").value.trim();
        const city = document.getElementById("city").value.trim();
        const province = document.getElementById("province").value.trim();
        const beds = document.getElementById("beds").value.trim();
        const maxPrice = document.getElementById("maxPrice").value.trim();

        const url = `/Listings/Search?query=${encodeURIComponent(query)}&city=${encodeURIComponent(city)}&province=${encodeURIComponent(province)}&beds=${encodeURIComponent(beds)}&maxPrice=${encodeURIComponent(maxPrice)}`;

        try {
            const res = await fetch(url);
            const data = await res.json();

            if (!data.ok) {
                showError(data.message || "Could not load listings right now.");
                listingStatus.textContent = "Search for a city or area to load rental listings.";
                return;
            }

            renderListings(data.items || []);
        } catch {
            showError("Request failed while loading listings.");
            listingStatus.textContent = "Search for a city or area to load rental listings.";
        }
    }

    form.addEventListener("submit", function (e) {
        e.preventDefault();
        loadListings();
    });
</script>