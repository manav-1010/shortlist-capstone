@model Shortlist.Web.Models.CompareIndexViewModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

<style>
    :root {
        --text: rgba(255,255,255,0.92);
        --muted: rgba(255,255,255,0.70);
        --border: rgba(255,255,255,0.12);
        --surface: rgba(255,255,255,0.06);
        --surface2: rgba(0,0,0,0.22);
        --accent: #4f46e5;
        --radius: 20px;
        --shadow: 0 18px 60px rgba(0,0,0,0.35);
    }

    body {
        background: radial-gradient(900px 380px at 15% 0%, rgba(79,70,229,0.35), transparent 60%), radial-gradient(700px 320px at 90% 30%, rgba(34,197,94,0.20), transparent 55%), linear-gradient(180deg, #07080c, #0b0d12 45%, #0b0d12);
    }

    .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 18px 16px;
        color: var(--text);
    }

    .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.05);
        border-radius: var(--radius);
        padding: 16px;
        box-shadow: var(--shadow);
    }

    .title h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 950;
        letter-spacing: -0.5px;
    }

    .title p {
        margin: 8px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
    }

    .btnx {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.06);
        color: var(--text);
        padding: 10px 12px;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

        .btnx.primary {
            background: linear-gradient(135deg, rgba(79,70,229,0.95), rgba(79,70,229,0.62));
            border-color: rgba(79,70,229,0.55);
        }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: 14px;
    }

    .card {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: rgba(0,0,0,0.20);
        padding: 14px;
        box-shadow: var(--shadow);
        min-height: 120px;
    }

    .k {
        color: var(--muted);
        font-weight: 850;
        font-size: 12px;
    }

    .v {
        color: var(--text);
        font-weight: 950;
        font-size: 15px;
        margin-top: 4px;
    }

    .pill {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.05);
        font-weight: 850;
        font-size: 12px;
        margin-top: 10px;
    }

    .mapBox {
        margin-top: 14px;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--border);
        background: rgba(0,0,0,0.22);
        height: 360px;
        box-shadow: var(--shadow);
    }

    #compareMap {
        height: 360px;
        width: 100%;
    }

    .empty {
        margin-top: 14px;
        border: 1px dashed rgba(255,255,255,0.20);
        border-radius: var(--radius);
        padding: 18px;
        background: rgba(0,0,0,0.20);
        color: var(--muted);
        font-weight: 800;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="wrap">
    <div class="top">
        <div class="title">
            <h1>Compare</h1>
            <p>Select up to 3 places from Results → compare side-by-side + export CSV.</p>
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <a class="btnx" href="/Results">Back to Results</a>
            <a class="btnx" href="/Compare/ExportCsv">Export CSV</a>
            <button id="btnClear" class="btnx primary" type="button">Clear Compare</button>
        </div>
    </div>

    @if (Model.Items == null || Model.Items.Count == 0)
    {
        <div class="empty">
            No items in Compare yet. Go to <b>Results</b> and click <b>Compare</b> on a place.
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var it in Model.Items)
            {
                <div class="card">
                    <div class="k">Place</div>
                    <div class="v">@it.Name</div>

                    <div class="pill">@it.Category</div>

                    <div style="margin-top:12px;">
                        <div class="k">Distance</div>
                        <div class="v">@it.DistKm.ToString("0.00") km</div>
                    </div>

                    <div style="margin-top:12px;">
                        <div class="k">Coordinates</div>
                        <div class="v">@it.Lat.ToString("0.0000"), @it.Lng.ToString("0.0000")</div>
                    </div>

                    <div style="margin-top:14px;">
                        <button class="btnx" type="button" onclick="removeItem('@it.Id')">Remove</button>
                    </div>
                </div>
            }
        </div>

        <div class="mapBox">
            <div id="compareMap"></div>
        </div>
    }
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script>
    const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));

    document.getElementById("btnClear")?.addEventListener("click", async () => {
        await fetch("/Compare/Clear", { method: "POST" });
        location.reload();
    });

    async function removeItem(id) {
        await fetch("/Compare/Remove", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(id)
        });
        location.reload();
    }

    // Map
    if (items && items.length) {
        const map = L.map("compareMap");
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19 }).addTo(map);

        const bounds = [];
        items.forEach((x) => {
            const m = L.marker([x.lat, x.lng]).addTo(map).bindPopup(
                `<b>${x.name}</b><br/>${x.category}<br/>${Number(x.distKm).toFixed(2)} km`
            );
            bounds.push(m.getLatLng());
        });

        if (bounds.length) map.fitBounds(bounds, { padding: [30, 30] });
        setTimeout(() => { try { map.invalidateSize(); } catch(e){} }, 200);
    }
</script>