@model Shortlist.Web.Models.CompareIndexViewModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

<style>
    :root {
        --bg: #dbe4f3;
        --bg2: #d2ddf0;
        --bg3: #e2e8f6;
        --surface: rgba(255, 255, 255, 0.78);
        --surface-strong: rgba(255, 255, 255, 0.88);
        --surface-soft: rgba(246, 249, 255, 0.72);
        --surface-deep: rgba(232, 239, 250, 0.88);
        --surface-tint: rgba(224, 231, 255, 0.86);
        --border: rgba(100, 116, 139, 0.18);
        --border-strong: rgba(100, 116, 139, 0.28);
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: rgba(79, 70, 229, 0.14);
        --info: #2563eb;
        --info-soft: rgba(37, 99, 235, 0.12);
        --danger: #b91c1c;
        --danger-soft: rgba(185, 28, 28, 0.10);
        --shadow-xl: 0 24px 70px rgba(15, 23, 42, 0.10);
        --shadow-lg: 0 18px 40px rgba(15, 23, 42, 0.08);
        --shadow-md: 0 10px 24px rgba(15, 23, 42, 0.06);
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
        --radius: 20px;
    }

    body {
        background: radial-gradient(1200px 700px at 0% -10%, rgba(79, 70, 229, 0.28), transparent 55%), radial-gradient(900px 600px at 100% 0%, rgba(37, 99, 235, 0.22), transparent 50%), radial-gradient(800px 500px at 50% 100%, rgba(14, 165, 233, 0.10), transparent 45%), linear-gradient(180deg, var(--bg) 0%, var(--bg2) 50%, var(--bg3) 100%);
    }

    .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 18px 16px 24px;
        color: var(--text);
    }

    .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        border: 1px solid var(--border);
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.16), transparent 58%), radial-gradient(560px 240px at 92% 18%, rgba(37,99,235,0.10), transparent 54%), linear-gradient(180deg, rgba(245, 248, 255, 0.80), rgba(233, 240, 250, 0.76));
        border-radius: 24px;
        padding: 18px 20px;
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(14px);
    }

    .title h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 950;
        letter-spacing: -0.5px;
        color: var(--text);
    }

    .title p {
        margin: 8px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.55;
    }

    .btnx {
        border-radius: 14px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 10px 13px;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,0.92);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: 14px;
    }

    .card {
        border: 1px solid var(--border);
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.78), rgba(232, 239, 250, 0.74));
        padding: 16px;
        box-shadow: var(--shadow-md);
        min-height: 120px;
        backdrop-filter: blur(12px);
    }

    .k {
        color: var(--muted2);
        font-weight: 850;
        font-size: 12px;
    }

    .v {
        color: var(--text);
        font-weight: 950;
        font-size: 15px;
        margin-top: 4px;
        line-height: 1.45;
    }

    .pill {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        color: var(--accent);
        font-weight: 850;
        font-size: 12px;
        margin-top: 10px;
    }

    .mapBox {
        margin-top: 14px;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.78), rgba(232, 239, 250, 0.74));
        height: 360px;
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(12px);
    }

    #compareMap {
        height: 360px;
        width: 100%;
    }

    .empty {
        margin-top: 14px;
        border: 1px dashed var(--border-strong);
        border-radius: 24px;
        padding: 20px;
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.78), rgba(232, 239, 250, 0.74));
        color: var(--muted);
        font-weight: 800;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(12px);
    }

    .leaflet-popup-content-wrapper,
    .leaflet-popup-tip {
        background: rgba(248, 250, 255, 0.96) !important;
        color: var(--text) !important;
        border: 1px solid var(--border) !important;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.10) !important;
    }

    .leaflet-popup-content {
        color: var(--text) !important;
        font-weight: 850 !important;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="wrap">
    <div class="top">
        <div class="title">
            <h1>Compare</h1>
            <p>Select up to 3 places from Results → compare side-by-side + export CSV.</p>
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <a class="btnx" href="/Results">Back to Results</a>
            <a class="btnx" href="/Compare/ExportCsv">Export CSV</a>
            <button id="btnClear" class="btnx primary" type="button">Clear Compare</button>
        </div>
    </div>

    @if (Model.Items == null || Model.Items.Count == 0)
    {
        <div class="empty">
            No items in Compare yet. Go to <b>Results</b> and click <b>Compare</b> on a place.
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var it in Model.Items)
            {
                <div class="card">
                    <div class="k">Place</div>
                    <div class="v">@it.Name</div>

                    <div class="pill">@it.Category</div>

                    <div style="margin-top:12px;">
                        <div class="k">Distance</div>
                        <div class="v">@it.DistKm.ToString("0.00") km</div>
                    </div>

                    <div style="margin-top:12px;">
                        <div class="k">Coordinates</div>
                        <div class="v">@it.Lat.ToString("0.0000"), @it.Lng.ToString("0.0000")</div>
                    </div>

                    <div style="margin-top:14px;">
                        <button class="btnx" type="button" onclick="removeItem('@it.Id')">Remove</button>
                    </div>
                </div>
            }
        </div>

        <div class="mapBox">
            <div id="compareMap"></div>
        </div>
    }
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script>
    const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));

    document.getElementById("btnClear")?.addEventListener("click", async () => {
        await fetch("/Compare/Clear", { method: "POST" });
        location.reload();
    });

    async function removeItem(id) {
        await fetch("/Compare/Remove", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(id)
        });
        location.reload();
    }

    // Map
    if (items && items.length) {
        const map = L.map("compareMap");
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19 }).addTo(map);

        const bounds = [];
        items.forEach((x) => {
            const m = L.marker([x.lat, x.lng]).addTo(map).bindPopup(
                `<b>${x.name}</b><br/>${x.category}<br/>${Number(x.distKm).toFixed(2)} km`
            );
            bounds.push(m.getLatLng());
        });

        if (bounds.length) map.fitBounds(bounds, { padding: [30, 30] });
        setTimeout(() => { try { map.invalidateSize(); } catch(e){} }, 200);
    }
</script>