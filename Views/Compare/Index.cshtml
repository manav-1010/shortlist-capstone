@model Shortlist.Web.Models.CompareIndexViewModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

<style>
    .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 18px 16px 24px;
        color: var(--text);
    }

    .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        border: 1px solid var(--border);
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.16), transparent 58%), radial-gradient(560px 240px at 92% 18%, rgba(37,99,235,0.10), transparent 54%), linear-gradient(180deg, var(--surface-strong), var(--surface));
        border-radius: 24px;
        padding: 18px 20px;
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(14px);
    }

    .title h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 950;
        letter-spacing: -0.5px;
        color: var(--text);
    }

    .title p {
        margin: 8px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.55;
    }

    .btnx {
        border-radius: 14px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 10px 13px;
        font-weight: 900;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

        .btnx.danger {
            background: rgba(254, 242, 242, 0.88);
            border-color: rgba(185, 28, 28, 0.18);
            color: #b91c1c;
        }

            .btnx.danger:hover {
                background: rgba(254, 226, 226, 0.95);
                border-color: rgba(185, 28, 28, 0.26);
            }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: 14px;
    }

    .card {
        border: 1px solid var(--border);
        border-radius: 22px;
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        padding: 16px;
        box-shadow: var(--shadow-md);
        min-height: 120px;
        backdrop-filter: blur(12px);
    }

    .k {
        color: var(--muted2);
        font-weight: 850;
        font-size: 12px;
    }

    .v {
        color: var(--text);
        font-weight: 950;
        font-size: 15px;
        margin-top: 4px;
        line-height: 1.45;
    }

    .pill {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        color: var(--accent);
        font-weight: 850;
        font-size: 12px;
        margin-top: 10px;
    }

    .mapBox {
        margin-top: 14px;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        height: 360px;
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(12px);
    }

    #compareMap {
        height: 360px;
        width: 100%;
    }

    .empty {
        margin-top: 14px;
        border: 1px dashed var(--border-strong);
        border-radius: 24px;
        padding: 20px;
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        color: var(--muted);
        font-weight: 800;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(12px);
    }

    .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 2000;
        padding: 11px 14px;
        border-radius: 14px;
        background: rgba(15, 23, 42, 0.92);
        color: #ffffff;
        font-weight: 850;
        font-size: 13px;
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.20);
        display: none;
    }

        .toast.show {
            display: block;
        }

    .leaflet-popup-content-wrapper,
    .leaflet-popup-tip {
        background: var(--surface-strong) !important;
        color: var(--text) !important;
        border: 1px solid var(--border) !important;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.10) !important;
    }

    .leaflet-popup-content {
        color: var(--text) !important;
        font-weight: 850 !important;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="wrap">
    <div class="top">
        <div class="title">
            <h1>Compare</h1>
            <p>Select up to 3 places from Results and compare them side by side.</p>
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <a class="btnx" href="/Results">Back to Results</a>
            <a class="btnx" href="/Compare/ExportCsv">Export CSV</a>
            <button id="btnClear" class="btnx primary" type="button">Clear Compare</button>
        </div>
    </div>

    @if (Model.Items == null || Model.Items.Count == 0)
    {
        <div class="empty">
            No items in Compare yet. Go to <b>Results</b> and click <b>Compare</b> on a place.
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var it in Model.Items)
            {
                <div class="card">
                    <div class="k">Place</div>
                    <div class="v">@it.Name</div>

                    <div class="pill">@it.Category</div>

                    <div style="margin-top:12px;">
                        <div class="k">Distance</div>
                        <div class="v">@it.DistKm.ToString("0.00") km</div>
                    </div>

                    <div style="margin-top:12px;">
                        <div class="k">Coordinates</div>
                        <div class="v">@it.Lat.ToString("0.0000"), @it.Lng.ToString("0.0000")</div>
                    </div>

                    <div style="margin-top:14px;">
                        <button class="btnx danger" type="button" onclick="removeItem('@it.Id')">Remove</button>
                    </div>
                </div>
            }
        </div>

        <div class="mapBox">
            <div id="compareMap"></div>
        </div>
    }
</div>

<div id="toast" class="toast"></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script>
    const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items ?? new List<Shortlist.Web.Models.CompareItem>()));

    function showToast(message) {
        const toast = document.getElementById("toast");
        if (!toast) return;
        toast.textContent = message;
        toast.classList.add("show");
        setTimeout(() => toast.classList.remove("show"), 1800);
    }

    document.getElementById("btnClear")?.addEventListener("click", async () => {
        const ok = confirm("Clear all compare items?");
        if (!ok) return;

        try {
            const res = await fetch("/Compare/Clear", {
                method: "POST"
            });

            if (!res.ok) {
                alert("Could not clear compare list.");
                return;
            }

            showToast("Compare list cleared");
            setTimeout(() => location.reload(), 500);
        } catch (e) {
            alert("Something went wrong while clearing compare.");
        }
    });

    async function removeItem(id) {
        const ok = confirm("Remove this item from compare?");
        if (!ok) return;

        try {
            const res = await fetch("/Compare/Remove", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(id)
            });

            if (!res.ok) {
                const txt = await res.text();
                alert("Could not remove item." + (txt ? "\n" + txt : ""));
                return;
            }

            showToast("Item removed");
            setTimeout(() => location.reload(), 500);
        } catch (e) {
            alert("Something went wrong while removing item.");
        }
    }

    if (items && items.length) {
        const map = L.map("compareMap");

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        const bounds = [];

        items.forEach((x) => {
            const marker = L.marker([x.lat, x.lng]).addTo(map).bindPopup(
                `<b>${x.name}</b><br/>${x.category}<br/>${Number(x.distKm).toFixed(2)} km`
            );

            bounds.push(marker.getLatLng());
        });

        if (bounds.length) {
            map.fitBounds(bounds, { padding: [30, 30] });
        } else {
            map.setView([43.4516, -80.4925], 12);
        }

        setTimeout(() => {
            try { map.invalidateSize(); } catch (e) { }
        }, 250);
    }
</script>