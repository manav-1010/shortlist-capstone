@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg: #f5f7fb;
        --bg2: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --surface-tint: #eef2ff;
        --border: #dbe3ee;
        --border-strong: #cbd5e1;
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --good: #15803d;
        --good-soft: #e8f7ee;
        --warn: #b45309;
        --warn-soft: #fff7ed;
        --bad: #b91c1c;
        --bad-soft: #fef2f2;
        --shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
        --shadow2: 0 10px 24px rgba(15, 23, 42, 0.06);
        --radius: 20px;
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    body {
        background: radial-gradient(1000px 500px at 10% -5%, rgba(79,70,229,0.10), transparent 60%), radial-gradient(900px 460px at 100% 0%, rgba(34,197,94,0.08), transparent 58%), linear-gradient(180deg, var(--bg), var(--bg2));
    }

    .shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 18px 16px 28px;
        color: var(--text);
    }

    .hero {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.08), transparent 60%), radial-gradient(560px 240px at 92% 18%, rgba(34,197,94,0.07), transparent 55%), linear-gradient(180deg, #ffffff, #f8fbff);
        box-shadow: var(--shadow2);
        padding: 18px;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 14px;
        align-items: center;
    }

    h1 {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.6px;
        font-weight: 950;
        color: var(--text);
    }

    .sub {
        margin-top: 8px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.6;
    }

    .actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 11px 14px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: var(--shadow2);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btn:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: var(--border-strong);
        }

        .btn:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btn.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: var(--accent);
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btn.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
                border-color: var(--accent-hover);
            }

    .grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 14px;
    }

    .card {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #fbfdff);
        box-shadow: var(--shadow2);
        padding: 16px;
    }

        .card h2 {
            margin: 0 0 10px;
            font-size: 16px;
            font-weight: 950;
            letter-spacing: -0.2px;
            color: var(--text);
        }

    .hint {
        color: var(--muted);
        font-weight: 750;
        font-size: 12px;
        line-height: 1.6;
        margin-top: -4px;
        margin-bottom: 10px;
    }

    .list {
        display: grid;
        gap: 10px;
    }

    .item {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 10px 10px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--surface-soft);
    }

        .item input {
            margin-top: 3px;
            transform: scale(1.1);
            accent-color: var(--accent);
        }

        .item .t {
            font-weight: 900;
            color: var(--text);
            font-size: 13px;
        }

        .item .p {
            margin-top: 4px;
            color: var(--muted);
            font-weight: 750;
            font-size: 12px;
            line-height: 1.55;
        }

    .pillRow {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .pill {
        padding: 7px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        font-weight: 850;
        font-size: 12px;
    }

        .pill.good {
            border-color: #bbf7d0;
            background: var(--good-soft);
            color: var(--good);
        }

        .pill.warn {
            border-color: #fed7aa;
            background: var(--warn-soft);
            color: var(--warn);
        }

        .pill.bad {
            border-color: #fecaca;
            background: var(--bad-soft);
            color: var(--bad);
        }

    details {
        margin-top: 12px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--surface-soft);
        padding: 12px;
    }

        details summary {
            cursor: pointer;
            font-weight: 950;
            color: var(--text);
            list-style: none;
        }

            details summary::-webkit-details-marker {
                display: none;
            }

        details .content {
            margin-top: 10px;
            color: var(--muted);
            font-weight: 750;
            font-size: 12px;
            line-height: 1.65;
        }

    .links a {
        color: var(--accent);
        font-weight: 900;
        text-decoration: none;
    }

        .links a:hover {
            text-decoration: underline;
            color: var(--accent-hover);
        }

    @@media (max-width: 980px) {
        .hero {
            grid-template-columns: 1fr;
        }

        .actions {
            justify-content: flex-start;
        }

        .grid {
            grid-template-columns: 1fr;
        }
    }

    @@media print {
        body {
            background: #fff !important;
        }

        .hero, .card, details {
            box-shadow: none !important;
        }

        .btn {
            display: none !important;
        }

        .shell {
            color: #000 !important;
        }

        .item, .card, .hero, details {
            background: #fff !important;
            border: 1px solid #ddd !important;
        }

            .item .t, .item .p, .hint, .sub, .pill, .links a, h1, h2 {
                color: #000 !important;
            }

        .links a {
            text-decoration: underline !important;
        }
    }
</style>

<div class="shell">
    <section class="hero">
        <div>
            <h1>Tenant Checklist</h1>
            <div class="sub">
                A real, practical checklist to help you move from “Shortlist results” to “sign the lease” with confidence.
                You can print this page and take it with you for viewings.
            </div>
        </div>

        <div class="actions">
            <button class="btn primary" type="button" onclick="window.print()">Print / Save PDF</button>
            <a class="btn" href="/Results">Back to Results</a>
        </div>
    </section>

    <section class="grid">
        <!-- LEFT COLUMN -->
        <div class="card">
            <h2>Before you book a viewing</h2>
            <div class="hint">Goal: avoid scams and filter out bad listings early.</div>

            <div class="list">
                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Confirm the address is real</div>
                        <div class="p">Search the address and check if photos match. Be cautious if the same images appear on multiple sites.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Ask basic questions in writing</div>
                        <div class="p">Rent, utilities, parking, availability date, lease length, and application requirements.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Never pay to “hold” a unit before you view</div>
                        <div class="p">A legitimate landlord should allow a viewing and provide paperwork before money changes hands.</div>
                    </div>
                </div>
            </div>

            <details>
                <summary>Viewing checklist (what to check on-site)</summary>
                <div class="content">
                    <div class="list">
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Water pressure + hot water</div>
                                <div class="p">Test sinks and shower. Check for leaks under the sink.</div>
                            </div>
                        </div>
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Windows, locks, and cell signal</div>
                                <div class="p">Open and close windows, confirm doors lock properly, and check signal if that matters to you.</div>
                            </div>
                        </div>
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Noise level</div>
                                <div class="p">Hallway noise, traffic, and nearby construction can become deal breakers.</div>
                            </div>
                        </div>
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Heating, cooling, and ventilation</div>
                                <div class="p">Ask how heating works and who controls it: the unit or the building.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </details>

            <details>
                <summary>Application package (what to prepare)</summary>
                <div class="content">
                    <div class="list">
                        <div class="item"><input type="checkbox" /><div><div class="t">Proof of income</div><div class="p">Pay stubs, offer letter, or bank statements — only what is actually required.</div></div></div>
                        <div class="item"><input type="checkbox" /><div><div class="t">References</div><div class="p">Previous landlord and employer references if possible.</div></div></div>
                        <div class="item"><input type="checkbox" /><div><div class="t">ID (safe sharing)</div><div class="p">Bring ID for viewing. Avoid sending unnecessary sensitive documents unless required.</div></div></div>
                    </div>
                </div>
            </details>

            <details>
                <summary>Lease signing (don’t skip these)</summary>
                <div class="content">
                    <div class="list">
                        <div class="item"><input type="checkbox" /><div><div class="t">Read everything and clarify utilities</div><div class="p">Confirm what’s included: hydro, water, internet, parking, and storage.</div></div></div>
                        <div class="item"><input type="checkbox" /><div><div class="t">Get receipts and keep a copy</div><div class="p">Always keep proof for deposits, first month’s rent, and a signed copy of the lease.</div></div></div>
                        <div class="item"><input type="checkbox" /><div><div class="t">Move-in inspection photos</div><div class="p">Record the condition on day one with photos or video to avoid disputes later.</div></div></div>
                    </div>
                </div>
            </details>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="card">
            <h2>Scam red flags</h2>
            <div class="hint">If you see more than one red flag, walk away.</div>

            <div class="pillRow">
                <span class="pill bad">Money before viewing</span>
                <span class="pill bad">Pressure / urgency</span>
                <span class="pill warn">Unverified identity</span>
                <span class="pill warn">Too-good-to-be-true price</span>
                <span class="pill bad">No lease / no paperwork</span>
            </div>

            <div class="list" style="margin-top:12px;">
                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">They won’t show the unit</div>
                        <div class="p">Excuses like “I’m out of the country” plus a request for deposit are a classic scam pattern.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">They insist on unusual payments</div>
                        <div class="p">Gift cards, crypto, wire transfers, or “friends & family” payments are unsafe.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">The listing details keep changing</div>
                        <div class="p">Rent amount, address, or included utilities changes when you ask basic questions.</div>
                    </div>
                </div>
            </div>

            <details class="links">
                <summary>Helpful links (Ontario)</summary>
                <div class="content">
                    <div>• Landlord and Tenant Board (LTB): <a href="https://tribunalsontario.ca/ltb/" target="_blank" rel="noopener noreferrer">tribunalsontario.ca/ltb</a></div>
                    <div>• Ontario Standard Lease info: <a href="https://www.ontario.ca/page/guide-ontarios-standard-lease" target="_blank" rel="noopener noreferrer">ontario.ca/page/guide-ontarios-standard-lease</a></div>
                    <div>• Tenant rights overview: <a href="https://www.ontario.ca/page/renting-ontario-your-rights" target="_blank" rel="noopener noreferrer">ontario.ca/page/renting-ontario-your-rights</a></div>
                    <div style="margin-top:8px; color: var(--muted);">
                        Tip: You can add a city-specific resources section later for Waterloo, Kitchener, or Toronto.
                    </div>
                </div>
            </details>
        </div>
    </section>
</div>