@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg: #dbe4f3;
        --bg2: #d2ddf0;
        --bg3: #e2e8f6;
        --surface: rgba(255, 255, 255, 0.78);
        --surface-strong: rgba(255, 255, 255, 0.88);
        --surface-soft: rgba(246, 249, 255, 0.72);
        --surface-tint: rgba(224, 231, 255, 0.86);
        --border: rgba(100, 116, 139, 0.18);
        --border-strong: rgba(100, 116, 139, 0.28);
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: rgba(79, 70, 229, 0.14);
        --good: #15803d;
        --good-soft: rgba(21, 128, 61, 0.12);
        --warn: #b45309;
        --warn-soft: rgba(245, 158, 11, 0.14);
        --bad: #b91c1c;
        --bad-soft: rgba(220, 38, 38, 0.12);
        --shadow-xl: 0 24px 70px rgba(15, 23, 42, 0.10);
        --shadow-lg: 0 18px 40px rgba(15, 23, 42, 0.08);
        --shadow-md: 0 10px 24px rgba(15, 23, 42, 0.06);
        --radius: 22px;
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    body {
        background: radial-gradient(1200px 700px at 0% -10%, rgba(79, 70, 229, 0.28), transparent 55%), radial-gradient(900px 600px at 100% 0%, rgba(37, 99, 235, 0.22), transparent 50%), radial-gradient(800px 500px at 50% 100%, rgba(14, 165, 233, 0.10), transparent 45%), linear-gradient(180deg, var(--bg) 0%, var(--bg2) 50%, var(--bg3) 100%);
    }

    .shell {
        max-width: 1220px;
        margin: 0 auto;
        padding: 20px 16px 30px;
        color: var(--text);
    }

    .hero {
        border: 1px solid var(--border);
        border-radius: 26px;
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.16), transparent 58%), radial-gradient(560px 240px at 92% 18%, rgba(37,99,235,0.10), transparent 54%), linear-gradient(180deg, rgba(245, 248, 255, 0.82), rgba(233, 240, 250, 0.78));
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(14px);
        padding: 22px;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 16px;
        align-items: center;
    }

    h1 {
        margin: 0;
        font-size: 30px;
        letter-spacing: -0.7px;
        font-weight: 950;
        color: var(--text);
    }

    .sub {
        margin-top: 8px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.7;
        max-width: 62ch;
    }

    .hero-pills {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 11px;
        border-radius: 999px;
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        color: var(--accent);
        font-weight: 850;
        font-size: 12px;
        box-shadow: var(--shadow-md);
    }

        .hero-pill.good {
            border-color: rgba(21, 128, 61, 0.18);
            background: rgba(232, 247, 238, 0.86);
            color: var(--good);
        }

    .actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 11px 14px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btn:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,0.92);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btn:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btn.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btn.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

    .topStats {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .stat {
        border-radius: 18px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.80), rgba(232, 239, 250, 0.76));
        box-shadow: var(--shadow-md);
        padding: 14px;
        backdrop-filter: blur(10px);
    }

        .stat .k {
            color: var(--muted2);
            font-weight: 850;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .3px;
        }

        .stat .v {
            color: var(--text);
            font-weight: 950;
            font-size: 16px;
            margin-top: 5px;
        }

        .stat .s {
            color: var(--muted);
            font-weight: 750;
            font-size: 12px;
            margin-top: 4px;
            line-height: 1.5;
        }

    .grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 14px;
    }

    .card {
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.80), rgba(232, 239, 250, 0.76));
        box-shadow: var(--shadow-md);
        padding: 18px;
        backdrop-filter: blur(12px);
    }

        .card h2 {
            margin: 0 0 10px;
            font-size: 17px;
            font-weight: 950;
            letter-spacing: -0.25px;
            color: var(--text);
        }

    .hint {
        color: var(--muted);
        font-weight: 750;
        font-size: 12px;
        line-height: 1.65;
        margin-top: -2px;
        margin-bottom: 12px;
    }

    .list {
        display: grid;
        gap: 10px;
    }

    .item {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 12px;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: rgba(248, 250, 255, 0.82);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
    }

        .item input {
            margin-top: 4px;
            transform: scale(1.1);
            accent-color: var(--accent);
        }

        .item .t {
            font-weight: 900;
            color: var(--text);
            font-size: 13px;
        }

        .item .p {
            margin-top: 4px;
            color: var(--muted);
            font-weight: 750;
            font-size: 12px;
            line-height: 1.6;
        }

    .pillRow {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .pill {
        padding: 7px 10px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        font-weight: 850;
        font-size: 12px;
        box-shadow: var(--shadow-md);
    }

        .pill.good {
            border-color: rgba(21, 128, 61, 0.18);
            background: rgba(232, 247, 238, 0.86);
            color: var(--good);
        }

        .pill.warn {
            border-color: rgba(245, 158, 11, 0.20);
            background: rgba(255, 247, 237, 0.84);
            color: var(--warn);
        }

        .pill.bad {
            border-color: rgba(220, 38, 38, 0.18);
            background: rgba(254, 242, 242, 0.86);
            color: var(--bad);
        }

    details {
        margin-top: 12px;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: rgba(248, 250, 255, 0.80);
        padding: 12px 14px;
        box-shadow: var(--shadow-md);
    }

        details summary {
            cursor: pointer;
            font-weight: 950;
            color: var(--text);
            list-style: none;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

            details summary::-webkit-details-marker {
                display: none;
            }

            details summary::after {
                content: "+";
                font-size: 18px;
                font-weight: 900;
                color: var(--accent);
            }

        details[open] summary::after {
            content: "–";
        }

        details .content {
            margin-top: 12px;
            color: var(--muted);
            font-weight: 750;
            font-size: 12px;
            line-height: 1.7;
        }

    .links a {
        color: var(--accent);
        font-weight: 900;
        text-decoration: none;
    }

        .links a:hover {
            text-decoration: underline;
            color: var(--accent-hover);
        }

    .noteBox {
        margin-top: 14px;
        border-radius: 16px;
        border: 1px solid rgba(79, 70, 229, 0.16);
        background: rgba(224, 231, 255, 0.70);
        padding: 12px 14px;
        color: var(--accent);
        font-size: 12px;
        font-weight: 800;
        line-height: 1.65;
        box-shadow: var(--shadow-md);
    }

    .miniSection {
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid rgba(100, 116, 139, 0.16);
    }

    .miniTitle {
        font-size: 13px;
        font-weight: 950;
        color: var(--text);
        margin-bottom: 8px;
    }

    @@media (max-width: 980px) {
        .hero {
            grid-template-columns: 1fr;
        }

        .actions {
            justify-content: flex-start;
        }

        .grid {
            grid-template-columns: 1fr;
        }

        .topStats {
            grid-template-columns: 1fr;
        }
    }

    @@media print {
        body {
            background: #fff !important;
        }

        .hero, .card, details, .stat {
            box-shadow: none !important;
            background: #fff !important;
            border: 1px solid #ddd !important;
        }

        .btn {
            display: none !important;
        }

        .shell {
            color: #000 !important;
        }

        .item {
            background: #fff !important;
            border: 1px solid #ddd !important;
        }

            .item .t,
            .item .p,
            .hint,
            .sub,
            .pill,
            .links a,
            h1,
            h2,
            .stat .k,
            .stat .v,
            .stat .s {
                color: #000 !important;
            }

        .links a {
            text-decoration: underline !important;
        }
    }
</style>

<div class="shell">
    <section class="hero">
        <div>
            <h1>Tenant Checklist</h1>
            <div class="sub">
                A practical checklist to help you move from “Shortlist results” to “sign the lease” with confidence.
                Use this page during searches, viewings, and applications so you do not miss anything important.
            </div>

            <div class="hero-pills">
                <span class="hero-pill">Viewing prep</span>
                <span class="hero-pill good">Scam awareness</span>
                <span class="hero-pill">Lease readiness</span>
            </div>
        </div>

        <div class="actions">
            <button class="btn primary" type="button" onclick="window.print()">Print / Save PDF</button>
            <a class="btn" href="/Results">Back to Results</a>
        </div>
    </section>

    <section class="topStats">
        <div class="stat">
            <div class="k">Step 1</div>
            <div class="v">Screen the listing</div>
            <div class="s">Check price, address, landlord communication, and obvious red flags.</div>
        </div>
        <div class="stat">
            <div class="k">Step 2</div>
            <div class="v">Inspect carefully</div>
            <div class="s">Use the checklist during the viewing so details are not missed.</div>
        </div>
        <div class="stat">
            <div class="k">Step 3</div>
            <div class="v">Document everything</div>
            <div class="s">Keep receipts, copies, photos, and written confirmations.</div>
        </div>
    </section>

    <section class="grid">
        <div class="card">
            <h2>Before you book a viewing</h2>
            <div class="hint">Goal: avoid scams and filter out weak listings early.</div>

            <div class="list">
                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Confirm the address is real</div>
                        <div class="p">Search the address, compare listing photos, and check whether the same photos appear on unrelated websites.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Ask basic questions in writing</div>
                        <div class="p">Confirm rent, utilities, parking, move-in date, lease term, deposits, and application requirements before visiting.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Do not pay before viewing</div>
                        <div class="p">A legitimate landlord or property manager should provide a viewing and proper documentation before asking for money.</div>
                    </div>
                </div>
            </div>

            <div class="noteBox">
                Tip: Save screenshots of the original listing before it changes or disappears.
            </div>

            <details>
                <summary>Viewing checklist (what to check on-site)</summary>
                <div class="content">
                    <div class="list">
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Water pressure and hot water</div>
                                <div class="p">Test sinks and shower, check how quickly hot water arrives, and look for leaks underneath.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Windows, locks, and phone signal</div>
                                <div class="p">Open and close windows, test locks, and check phone signal if you rely on mobile data indoors.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Noise level</div>
                                <div class="p">Listen for traffic, hallways, neighbors, building systems, and nearby construction noise.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Heating, cooling, and ventilation</div>
                                <div class="p">Ask how temperature is controlled and whether the tenant or building manages it.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </details>

            <details>
                <summary>Application package (what to prepare)</summary>
                <div class="content">
                    <div class="list">
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Proof of income</div>
                                <div class="p">Prepare pay stubs, an offer letter, or limited supporting documents only if reasonably requested.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">References</div>
                                <div class="p">Keep previous landlord, roommate, or employer references ready if the application process asks for them.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">ID and safe document sharing</div>
                                <div class="p">Bring ID in person, but avoid sending unnecessary sensitive records unless truly required.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </details>

            <details>
                <summary>Lease signing (do not skip these)</summary>
                <div class="content">
                    <div class="list">
                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Read the lease carefully</div>
                                <div class="p">Review rent amount, included utilities, lease term, parking, maintenance responsibility, and building rules.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Keep receipts and signed copies</div>
                                <div class="p">Save payment confirmations, lease copies, emails, and any move-in documents.</div>
                            </div>
                        </div>

                        <div class="item">
                            <input type="checkbox" />
                            <div>
                                <div class="t">Take move-in condition photos</div>
                                <div class="p">Photograph walls, appliances, floors, and damage on day one to prevent later disputes.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </details>
        </div>

        <div class="card">
            <h2>Scam red flags</h2>
            <div class="hint">If you notice multiple red flags together, it is safer to walk away.</div>

            <div class="pillRow">
                <span class="pill bad">Money before viewing</span>
                <span class="pill bad">Pressure / urgency</span>
                <span class="pill warn">Unverified identity</span>
                <span class="pill warn">Too-good-to-be-true price</span>
                <span class="pill bad">No lease / no paperwork</span>
            </div>

            <div class="list" style="margin-top:12px;">
                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">They refuse to show the unit</div>
                        <div class="p">Excuses like “I’m out of the country” combined with a deposit request are common warning signs.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">They ask for unusual payment methods</div>
                        <div class="p">Gift cards, crypto, wire transfers, or personal transfer arrangements are high-risk.</div>
                    </div>
                </div>

                <div class="item">
                    <input type="checkbox" />
                    <div>
                        <div class="t">Important details keep changing</div>
                        <div class="p">The address, rent, included utilities, or move-in date changes after you ask follow-up questions.</div>
                    </div>
                </div>
            </div>

            <div class="miniSection">
                <div class="miniTitle">Good practice during communication</div>
                <div class="list">
                    <div class="item">
                        <input type="checkbox" />
                        <div>
                            <div class="t">Keep messages in writing</div>
                            <div class="p">Email or platform messages are easier to reference later than phone-only conversations.</div>
                        </div>
                    </div>

                    <div class="item">
                        <input type="checkbox" />
                        <div>
                            <div class="t">Bring someone to the viewing if possible</div>
                            <div class="p">A second person can notice issues you miss and adds confidence during the visit.</div>
                        </div>
                    </div>
                </div>
            </div>

            <details class="links">
                <summary>Helpful links (Ontario)</summary>
                <div class="content">
                    <div>• Landlord and Tenant Board (LTB): <a href="https://tribunalsontario.ca/ltb/" target="_blank" rel="noopener noreferrer">tribunalsontario.ca/ltb</a></div>
                    <div>• Ontario Standard Lease guide: <a href="https://www.ontario.ca/page/guide-ontarios-standard-lease" target="_blank" rel="noopener noreferrer">ontario.ca/page/guide-ontarios-standard-lease</a></div>
                    <div>• Tenant rights overview: <a href="https://www.ontario.ca/page/renting-ontario-your-rights" target="_blank" rel="noopener noreferrer">ontario.ca/page/renting-ontario-your-rights</a></div>
                </div>
            </details>
        </div>
    </section>
</div>