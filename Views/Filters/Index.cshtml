@model Shortlist.Web.Models.FilterState
@{
    Layout = "_Layout";

    var allPriorities = new List<string>
    {
        "Safety",
        "Transit",
        "Grocery",
        "Quiet",
        "Parking",
        "Gym/Fitness",
        "Parks",
        "Laundry"
    };

    var selected = Model?.Priorities ?? new List<string>();
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<style>
    .filters-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 14px 16px 18px;
        color: var(--text);
    }

    .filters-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

    .title {
        margin: 0;
        font-size: 28px;
        font-weight: 950;
        letter-spacing: -0.4px;
        color: var(--text);
    }

    .subtitle {
        margin: 4px 0 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.55;
        max-width: 64ch;
    }

    .hintpill {
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        padding: 8px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 850;
        color: var(--accent);
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: var(--shadow-md);
    }

    .head-right {
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .icon-link {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: var(--surface);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(10px);
    }

        .icon-link:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: var(--border-strong);
            box-shadow: var(--shadow-lg);
        }

        .icon-link:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .icon-link svg {
            width: 18px;
            height: 18px;
            fill: var(--muted);
        }

    .layout {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 14px;
        align-items: stretch;
    }

    .panel {
        border-radius: 24px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, var(--surface-strong), var(--surface-soft));
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        backdrop-filter: blur(12px);
    }

    .panel-inner {
        padding: 16px;
    }

    .section-title {
        margin: 0 0 10px;
        font-size: 14px;
        font-weight: 950;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .field label {
            font-weight: 900;
            font-size: 12px;
            color: var(--text);
        }

    .inputx {
        width: 100%;
        padding: 10px 11px;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        outline: none;
        font-weight: 850;
        box-shadow: var(--shadow-md);
    }

        .inputx::placeholder {
            color: var(--muted2);
            font-weight: 750;
        }

        .inputx:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
        }

    .microhint {
        font-size: 11.5px;
        font-weight: 750;
        color: var(--muted2);
        line-height: 1.4;
    }

    .error {
        color: var(--bad);
        font-weight: 900;
        font-size: 12px;
    }

    .prio-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-top: 10px;
    }

    .count-pill {
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 950;
        font-size: 12px;
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        color: var(--accent);
        white-space: nowrap;
        box-shadow: var(--shadow-md);
    }

    .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .chip {
        border: 1px solid var(--border-strong);
        background: var(--surface);
        padding: 9px 12px;
        border-radius: 999px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 900;
        color: var(--text);
        transition: transform .1s ease, background .1s ease, border .1s ease, box-shadow .1s ease;
        user-select: none;
        box-shadow: var(--shadow-md);
    }

        .chip:hover {
            transform: translateY(-1px);
            border-color: rgba(99, 102, 241, 0.24);
            background: var(--surface-soft);
            box-shadow: var(--shadow-lg);
        }

        .chip:focus {
            outline: none;
            box-shadow: var(--focus);
            border-color: var(--accent);
        }

        .chip.selected {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
        }

    .prio-error {
        margin-top: 8px;
        color: var(--bad);
        font-weight: 900;
        font-size: 12px;
        display: none;
    }

    .map-wrap {
        display: grid;
        grid-template-rows: auto 1fr auto;
        height: 100%;
    }

    .map-top {
        padding: 12px 14px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        background: linear-gradient(180deg, var(--surface-strong), var(--surface));
    }

    .map-title {
        margin: 0;
        font-size: 14px;
        font-weight: 950;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .map-sub {
        margin: 0;
        color: var(--muted);
        font-weight: 750;
        font-size: 12px;
    }

    #filtersMap {
        height: calc(100vh - 260px);
        min-height: 320px;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
    }

    .map-controls {
        padding: 12px 14px;
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 10px;
        background: linear-gradient(180deg, var(--surface-strong), var(--surface));
    }

    .actionbar {
        position: sticky;
        bottom: 10px;
        margin-top: 12px;
        padding: 12px;
        border-radius: 18px;
        border: 1px solid var(--border);
        background: var(--surface-strong);
        backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        box-shadow: var(--shadow-lg);
    }

    .btnx {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
        user-select: none;
        min-width: 150px;
        box-shadow: var(--shadow-md);
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
            box-shadow: 0 16px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

        .btnx.danger {
            background: var(--bad-soft);
            border-color: rgba(185, 28, 28, 0.18);
            color: var(--bad);
        }

        .btnx.iconbtn {
            min-width: auto;
            width: 44px;
            height: 44px;
            padding: 0;
        }

            .btnx.iconbtn svg {
                width: 18px;
                height: 18px;
                fill: var(--muted);
            }

    .rightnote {
        color: var(--muted);
        font-weight: 850;
        font-size: 12px;
        line-height: 1.4;
    }

    .leaflet-popup-content-wrapper,
    .leaflet-popup-tip {
        background: var(--surface-strong) !important;
        color: var(--text) !important;
        border: 1px solid var(--border) !important;
        box-shadow: var(--shadow-lg) !important;
    }

    .leaflet-popup-content {
        color: var(--text) !important;
        font-weight: 850 !important;
    }

    @@media (max-width: 980px) {
        .layout {
            grid-template-columns: 1fr;
        }

        #filtersMap {
            height: 360px;
        }

        .map-controls {
            grid-template-columns: 1fr;
        }

        .actionbar {
            position: static;
        }
    }
</style>

<div class="filters-wrap">
    <div class="filters-head">
        <div>
            <h1 class="title">Filters</h1>
            <p class="subtitle">
                Pick a location on the map, then set budget + distance and choose up to 3 priorities.
            </p>
        </div>

        <!-- RIGHT: Hint + Settings shortcut -->
        <div class="head-right">
            <div class="hintpill">Click map → drop pin → Apply</div>

            <a asp-controller="Settings" asp-action="Index" class="icon-link" aria-label="Settings" title="Settings">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M19.14,12.94a7.43,7.43,0,0,0,.05-.94,7.43,7.43,0,0,0-.05-.94l2.11-1.65a.5.5,0,0,0,.12-.64l-2-3.46a.5.5,0,0,0-.6-.22l-2.49,1a7.28,7.28,0,0,0-1.63-.94l-.38-2.65A.5.5,0,0,0,13.8,2H10.2a.5.5,0,0,0-.49.42L9.33,5.07a7.28,7.28,0,0,0-1.63.94l-2.49-1a.5.5,0,0,0-.6.22l-2,3.46a.5.5,0,0,0,.12.64L4.86,11.06a7.43,7.43,0,0,0-.05.94,7.43,7.43,0,0,0,.05.94L2.75,14.59a.5.5,0,0,0-.12.64l2,3.46a.5.5,0,0,0,.6.22l2.49-1a7.28,7.28,0,0,0,1.63.94l.38,2.65a.5.5,0,0,0,.49.42h3.6a.5.5,0,0,0,.49-.42l.38-2.65a7.28,7.28,0,0,0,1.63-.94l2.49,1a.5.5,0,0,0,.6-.22l2-3.46a.5.5,0,0,0-.12-.64ZM12,15.5A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
                </svg>
            </a>
        </div>
    </div>

    <form method="post" id="filtersForm">
        <div class="layout">

            <!-- LEFT: Controls -->
            <section class="panel">
                <div class="panel-inner">
                    <div class="section-title">Budget & Distance</div>

                    <div class="grid2">
                        <div class="field">
                            <label for="Budget">Budget (monthly CAD)</label>
                            <input class="inputx" asp-for="Budget" id="Budget" type="number" step="1" min="0" placeholder="e.g., 1200" />
                            <div class="microhint">Leave blank if not sure.</div>
                            <span class="error" asp-validation-for="Budget"></span>
                        </div>

                        <div class="field">
                            <label for="MaxDistanceKm">Max Distance (km)</label>
                            <input class="inputx" asp-for="MaxDistanceKm" id="MaxDistanceKm" type="number" step="1" min="0" placeholder="e.g., 3" />
                            <div class="microhint">How far you're willing to travel.</div>
                            <span class="error" asp-validation-for="MaxDistanceKm"></span>
                        </div>
                    </div>

                    <div class="prio-head">
                        <div class="section-title" style="margin:12px 0 0;">Priorities</div>
                        <span id="priorityCount" class="count-pill">0/3</span>
                    </div>
                    <div class="microhint">Select up to 3. Click again to remove.</div>

                    <div id="priorityChips" class="chips" role="group" aria-label="Priorities">
                        @foreach (var p in allPriorities)
                        {
                            var isSelected = selected.Contains(p);
                            <button type="button"
                                    class="chip @(isSelected ? "selected" : "")"
                                    data-value="@p"
                                    aria-pressed="@(isSelected.ToString().ToLower())">
                                @p
                            </button>
                        }
                    </div>

                    <div id="priorityError" class="prio-error">
                        You can only select up to 3 priorities.
                    </div>

                    <div id="priorityHiddenInputs">
                        @foreach (var p in selected)
                        {
                            <input type="hidden" name="Priorities" value="@p" />
                        }
                    </div>

                    <!-- Hidden fields updated by map -->
                    <input type="hidden" asp-for="Lat" id="Lat" />
                    <input type="hidden" asp-for="Lng" id="Lng" />

                    <div class="actionbar">
                        <div class="rightnote">
                            Best results: choose a pin + 2–5 km radius.
                        </div>

                        <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; align-items:center;">
                            <!-- Settings shortcut inside action bar too -->
                            <a asp-controller="Settings" asp-action="Index" class="btnx iconbtn" aria-label="Settings" title="Settings">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M19.14,12.94a7.43,7.43,0,0,0,.05-.94,7.43,7.43,0,0,0-.05-.94l2.11-1.65a.5.5,0,0,0,.12-.64l-2-3.46a.5.5,0,0,0-.6-.22l-2.49,1a7.28,7.28,0,0,0-1.63-.94l-.38-2.65A.5.5,0,0,0,13.8,2H10.2a.5.5,0,0,0-.49.42L9.33,5.07a7.28,7.28,0,0,0-1.63.94l-2.49-1a.5.5,0,0,0-.6.22l-2,3.46a.5.5,0,0,0,.12.64L4.86,11.06a7.43,7.43,0,0,0-.05.94,7.43,7.43,0,0,0,.05.94L2.75,14.59a.5.5,0,0,0-.12.64l2,3.46a.5.5,0,0,0,.6.22l2.49-1a7.28,7.28,0,0,0,1.63.94l.38,2.65a.5.5,0,0,0,.49.42h3.6a.5.5,0,0,0,.49-.42l.38-2.65a7.28,7.28,0,0,0,1.63-.94l2.49,1a.5.5,0,0,0,.6-.22l2-3.46a.5.5,0,0,0-.12-.64ZM12,15.5A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
                                </svg>
                            </a>

                            <button type="submit" class="btnx primary">Apply Filters</button>

                            <button type="submit"
                                    class="btnx danger"
                                    formaction="@Url.Action("Reset", "Filters")"
                                    formmethod="post">
                                Reset
                            </button>

                            <a class="btnx" asp-controller="Results" asp-action="Index">View Results</a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- RIGHT: Map -->
            <section class="panel map-wrap">
                <div class="map-top">
                    <div>
                        <p class="map-title">Choose location on map</p>
                        <p class="map-sub">Click to drop a pin (drag to adjust).</p>
                    </div>
                    <div class="hintpill" style="padding:6px 10px;">Live Map</div>
                </div>

                <div id="filtersMap"></div>

                <div class="map-controls">
                    <div class="field">
                        <label for="RadiusKm">Radius (km)</label>
                        <input class="inputx" asp-for="RadiusKm" id="RadiusKm" type="number" min="1" max="25" step="1" />
                        <div class="microhint">Typical: 2–5 km</div>
                    </div>

                    <div class="field">
                        <label for="LocationLabel">Location label (optional)</label>
                        <input class="inputx" asp-for="LocationLabel" id="LocationLabel" type="text" placeholder="e.g., Uptown Waterloo" />
                        <div class="microhint">Helps you remember the spot.</div>
                    </div>
                </div>
            </section>

        </div>
    </form>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>

<script>
    (function () {
        const countEl = document.getElementById('priorityCount');
        const chipsWrap = document.getElementById('priorityChips');
        const hiddenWrap = document.getElementById('priorityHiddenInputs');
        const errorEl = document.getElementById('priorityError');

        function getSelected() {
            return Array.from(document.querySelectorAll('.chip.selected')).map(b => b.dataset.value);
        }

        function syncHidden(selected) {
            hiddenWrap.innerHTML = "";
            for (const p of selected) {
                const input = document.createElement("input");
                input.type = "hidden";
                input.name = "Priorities";
                input.value = p;
                hiddenWrap.appendChild(input);
            }
        }

        function syncCount(selected) {
            if (countEl) countEl.textContent = `${selected.length}/3`;
        }

        function showError(show) {
            if (!errorEl) return;
            errorEl.style.display = show ? "block" : "none";
        }

        // init count
        const initSel = getSelected();
        syncCount(initSel);
        syncHidden(initSel);

        // click behavior
        chipsWrap?.addEventListener("click", (e) => {
            const btn = e.target.closest(".chip");
            if (!btn) return;

            const isSelected = btn.classList.contains("selected");

            if (!isSelected) {
                const current = getSelected();
                if (current.length >= 3) {
                    showError(true);
                    return;
                }
                btn.classList.add("selected");
                btn.setAttribute("aria-pressed", "true");
                showError(false);
            } else {
                btn.classList.remove("selected");
                btn.setAttribute("aria-pressed", "false");
                showError(false);
            }

            const now = getSelected();
            syncCount(now);
            syncHidden(now);
        });
    })();
</script>

<script>
    (function () {
        const latInput = document.getElementById("Lat");
        const lngInput = document.getElementById("Lng");

        // Default center: Kitchener/Waterloo
        const initialLat = parseFloat(latInput?.value) || 43.4516;
        const initialLng = parseFloat(lngInput?.value) || -80.4925;

        const mapEl = document.getElementById("filtersMap");
        if (!mapEl) return;

        const map = L.map("filtersMap").setView([initialLat, initialLng], 13);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        let marker = null;

        function setPoint(lat, lng) {
            if (!marker) {
                marker = L.marker([lat, lng], { draggable: true }).addTo(map);
                marker.on("dragend", () => {
                    const p = marker.getLatLng();
                    latInput.value = p.lat.toFixed(6);
                    lngInput.value = p.lng.toFixed(6);
                });
            } else {
                marker.setLatLng([lat, lng]);
            }

            latInput.value = lat.toFixed(6);
            lngInput.value = lng.toFixed(6);
        }

        // If existing values are present, show marker
        if (latInput.value && lngInput.value) {
            setPoint(initialLat, initialLng);
        }

        map.on("click", (e) => {
            setPoint(e.latlng.lat, e.latlng.lng);
        });

        setTimeout(() => map.invalidateSize(), 150);
    })();
</script>