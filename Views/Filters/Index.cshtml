@model Shortlist.Web.Models.FilterState
@{
    var allPriorities = new List<string>
    {
        "Safety",
        "Transit",
        "Grocery",
        "Quiet",
        "Parking",
        "Gym/Fitness",
        "Parks",
        "Laundry"
    };

    var selected = Model?.Priorities ?? new List<string>();
}

<style>
    .filters-wrap {
        max-width: 900px;
        margin: 0 auto;
    }

    .page-title {
        font-size: 34px;
        margin: 6px 0;
    }

    .page-subtitle {
        color: var(--muted);
        margin: 0 0 18px;
    }

    .filters-card {
        padding: 20px;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 10px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .field label {
            font-weight: 800;
            font-size: 14px;
        }

    .hint {
        font-size: 13px;
        color: var(--muted);
        margin-top: 2px;
    }

    .divider {
        height: 1px;
        background: var(--border);
        margin: 18px 0;
    }

    .prio-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
    }

    .prio-title {
        font-weight: 900;
        margin: 0;
        font-size: 16px;
    }

    .count-pill {
        background: rgba(29, 78, 216, 0.08);
        color: var(--primary-dark);
        border: 1px solid rgba(29, 78, 216, 0.20);
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 13px;
        white-space: nowrap;
    }

    .priority-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 12px;
    }

    .priority-chip {
        border: 1px solid var(--border);
        background: var(--surface);
        padding: 10px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 800;
        color: var(--text);
    }

        .priority-chip.selected {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

    .priority-error {
        margin-top: 10px;
        color: var(--danger);
        font-weight: 800;
        display: none;
    }

    .actions {
        display: flex;
        gap: 10px;
        margin-top: 18px;
        flex-wrap: wrap;
    }

    

    {
        grid-template-columns: 1fr;
    }

    .page-title {
        font-size: 28px;
    }

    }
</style>

<div class="filters-wrap">
    <h1 class="page-title">Filters</h1>
    <p class="page-subtitle">Set your budget, max distance, and up to 3 priorities. Then apply to see your ranked areas.</p>

    <div class="card filters-card">
        <form method="post" id="filtersForm">

            <div class="filters-grid">
                <div class="field">
                    <label for="Budget">Budget (monthly)</label>
                    <input class="input" asp-for="Budget" id="Budget" type="number" step="1" min="0" placeholder="e.g., 1200" />
                    <div class="hint">Enter a number (CAD). Leave blank if not sure.</div>
                    <span class="field-error" asp-validation-for="Budget"></span>
                </div>

                <div class="field">
                    <label for="MaxDistanceKm">Max Distance (Km)</label>
                    <input class="input" asp-for="MaxDistanceKm" id="MaxDistanceKm" type="number" step="1" min="0" placeholder="e.g., 3" />
                    <div class="hint">How far you’re willing to travel.</div>
                    <span class="field-error" asp-validation-for="MaxDistanceKm"></span>
                </div>
            </div>

            <div class="divider"></div>

            <div class="prio-header">
                <p class="prio-title">Priorities (max 3)</p>
                <span id="priorityCount" class="count-pill">0/3</span>
            </div>

            <div class="hint">Click to select. Click again to remove.</div>

            <div id="priorityChips" class="priority-chips">
                @foreach (var p in allPriorities)
                {
                    var isSelected = selected.Contains(p);
                    <button type="button"
                            class="priority-chip @(isSelected ? "selected" : "")"
                            data-value="@p"
                            aria-pressed="@(isSelected.ToString().ToLower())">
                        @p
                    </button>
                }
            </div>

            <div id="priorityError" class="priority-error">
                You can only select up to 3 priorities.
            </div>

            <div id="priorityHiddenInputs">
                @foreach (var p in selected)
                {
                    <input type="hidden" name="Priorities" value="@p" />
                }
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary">Apply Filters</button>

                <button type="submit"
                        class="btn"
                        formaction="@Url.Action("Reset", "Filters")"
                        formmethod="post">
                    Reset
                </button>

                <a class="btn" href="/Results/Index">View Results</a>
            </div>
        </form>
    </div>
</div>

<script>
    (function () {
        const count = document.getElementById('priorityCount');
        const selected = document.querySelectorAll('.priority-chip.selected').length;
        if (count) count.textContent = `${selected}/3`;
    })();
</script>