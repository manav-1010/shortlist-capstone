@model List<Shortlist.Web.Models.SavedSearch>
@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg: #f5f7fb;
        --bg2: #eef3f9;
        --surface: #ffffff;
        --surface-soft: #f8fafc;
        --surface-tint: #eef2ff;
        --border: #dbe3ee;
        --border-strong: #cbd5e1;
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: #e9e7ff;
        --good: #15803d;
        --good-soft: #e8f7ee;
        --danger: #b91c1c;
        --danger-soft: #fef2f2;
        --shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
        --shadow2: 0 10px 24px rgba(15, 23, 42, 0.06);
        --radius: 20px;
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    body {
        background: radial-gradient(1000px 500px at 10% -5%, rgba(79,70,229,0.10), transparent 60%), radial-gradient(900px 460px at 100% 0%, rgba(34,197,94,0.08), transparent 58%), linear-gradient(180deg, var(--bg), var(--bg2));
    }

    .shell {
        max-width: 1080px;
        margin: 0 auto;
        padding: 18px 16px 24px;
        color: var(--text);
    }

    .saved-topbar {
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #f8fbff);
        box-shadow: var(--shadow2);
        padding: 18px;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 14px;
        align-items: center;
        margin-bottom: 14px;
    }

    .title h1 {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.6px;
        font-weight: 950;
        color: var(--text);
    }

    .title .sub {
        margin-top: 8px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 750;
        line-height: 1.5;
    }

    .saveForm {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
        justify-self: end;
        width: 100%;
        max-width: 520px;
    }

    .inputx {
        width: 100%;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 11px 12px;
        font-weight: 850;
        outline: none;
        box-shadow: var(--shadow2);
    }

        .inputx::placeholder {
            color: var(--muted2);
            font-weight: 750;
        }

        .inputx:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
        }

    .btnx {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--text);
        padding: 11px 14px;
        font-weight: 900;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
        user-select: none;
        white-space: nowrap;
        box-shadow: var(--shadow2);
    }

        .btnx:hover {
            transform: translateY(-1px);
            background: var(--surface-soft);
            border-color: var(--border-strong);
        }

        .btnx:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btnx.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: var(--accent);
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btnx.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
                border-color: var(--accent-hover);
            }

        .btnx.ghost {
            background: var(--surface);
            color: var(--text);
        }

        .btnx.danger {
            background: var(--danger-soft);
            border-color: #fecaca;
            color: var(--danger);
        }

            .btnx.danger:hover {
                background: #fee2e2;
                border-color: #fca5a5;
            }

        .btnx.mini {
            padding: 9px 12px;
            font-weight: 900;
        }

    .board {
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #fbfdff);
        box-shadow: var(--shadow2);
        overflow: hidden;
    }

    .boardHead {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #fafcff, #f6f9ff);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

        .boardHead .hint {
            color: var(--muted);
            font-weight: 800;
            font-size: 12px;
            line-height: 1.45;
        }

    .list {
        padding: 10px 12px;
    }

    .rowCard {
        border-radius: 18px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, #ffffff, #fbfdff);
        box-shadow: var(--shadow2);
        padding: 14px;
        margin: 10px 4px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        align-items: center;
    }

    .name {
        font-weight: 950;
        font-size: 15px;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .meta {
        color: var(--muted);
        font-size: 12px;
        font-weight: 750;
        margin-top: 6px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid #d8d4fe;
        background: var(--surface-tint);
        color: var(--accent);
        font-weight: 900;
        font-size: 11px;
    }

    .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .empty {
        padding: 22px 16px;
        color: var(--muted);
        font-weight: 800;
        text-align: center;
    }

    .toast {
        margin: 0 0 14px;
        border-radius: 16px;
        border: 1px solid #bbf7d0;
        background: var(--good-soft);
        padding: 12px 14px;
        color: var(--good);
        font-weight: 900;
        display: none;
        box-shadow: var(--shadow2);
    }

        .toast.on {
            display: block;
        }

    @@media (max-width: 900px) {
        .topbar {
            grid-template-columns: 1fr;
        }

        .saveForm {
            justify-self: stretch;
            max-width: none;
        }

        .rowCard {
            grid-template-columns: 1fr;
        }

        .actions {
            justify-content: flex-start;
        }
    }
</style>

<div class="shell">
    <div id="toast" class="toast"></div>

    @if (TempData["Toast"] != null)
    {
        <div class="toast on">@TempData["Toast"]</div>
    }

    <section class="saved-topbar">
        <div class="title">
            <h1>Saved Searches</h1>
            <div class="sub">
                Load, share, or delete your saved filter setups. Sharing creates a link anyone can open.
            </div>
        </div>

        <div class="saveForm">
            <input id="autoName" class="inputx" readonly
                   placeholder="Auto-name preview (based on your current Filters)" />
        </div>
    </section>

    <section class="board">
        <div class="boardHead">
            <div class="hint">
                Tip: Use <strong>Load</strong> to restore Filters → jump back to Results. Use <strong>Share</strong> to copy a link.
            </div>
        </div>

        <div class="list">
            @if (Model == null || Model.Count == 0)
            {
                <div class="empty">
                    No saved searches yet. Go to <strong>Filters</strong> → Apply → then come back here to save.
                </div>
            }
            else
            {
                foreach (var s in Model)
                {
                    var shareUrl = Url.Action(
                    "Share",
                    "SavedSearches",
                    new { token = s.ShareToken },
                    protocol: Context.Request.Scheme
                    );

                    <div class="rowCard">
                        <div>
                            <div class="name">@s.Name</div>
                            <div class="meta">
                                <span>Saved: @s.CreatedAtUtc.ToLocalTime()</span>
                                <span class="pill">Shareable link</span>
                            </div>
                        </div>

                        <div class="actions">
                            <form method="post" asp-action="Load" asp-route-id="@s.Id" style="margin:0;">
                                <button class="btnx primary mini" type="submit">Load</button>
                            </form>

                            <button class="btnx ghost mini" type="button"
                                    onclick="copyShareLink('@shareUrl')">
                                Share
                            </button>

                            <button class="btnx ghost mini" type="button"
                                    onclick="regenerateShare(@s.Id)">
                                Regenerate
                            </button>

                            <form method="post" asp-action="Delete" asp-route-id="@s.Id" style="margin:0;"
                                  onsubmit="return confirm('Delete this saved search?');">
                                <button class="btnx danger mini" type="submit">Delete</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<script>
    function showToast(msg) {
        const t = document.getElementById("toast");
        if (!t) return;
        t.textContent = msg;
        t.classList.add("on");
        setTimeout(() => t.classList.remove("on"), 2200);
    }

    async function copyShareLink(url) {
        try {
            await navigator.clipboard.writeText(url);
            showToast("Share link copied ✅");
        } catch {
            prompt("Copy this link:", url);
        }
    }

    async function regenerateShare(id) {
        try {
            const res = await fetch(`/SavedSearches/RegenerateShareLink?id=${encodeURIComponent(id)}`, {
                method: "POST"
            });

            if (!res.ok) {
                const t = await res.text();
                alert("Failed to regenerate link: " + t);
                return;
            }

            showToast("New share link generated ✅");
            setTimeout(() => location.reload(), 800);
        } catch (e) {
            alert("Failed to regenerate link.");
        }
    }

    async function getAutoName() {
        try {
            const res = await fetch("/Filters/GetCurrentFilterState");
            if (!res.ok) return;

            const data = await res.json();
            let parts = [];

            const budget = data.budget ?? data.Budget;
            const dist = data.maxDistanceKm ?? data.distanceKm ?? data.MaxDistanceKm;
            const priorities = data.priorities ?? data.Priorities ?? [];

            if (budget) parts.push("Budget $" + budget);
            if (dist) parts.push(dist + "km");
            if (priorities && priorities.length) parts.push(priorities.slice(0, 2).join("+"));

            document.getElementById("autoName").value = parts.join(" • ") || "No active filter state found";
        } catch { }
    }

    getAutoName();
</script>