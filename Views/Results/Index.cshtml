@model Shortlist.Web.Models.ResultsViewModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<style>
    .results-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    .results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .clear-btn {
        padding: 8px 14px;
        border-radius: 10px;
        border: none;
        background: #eee;
        cursor: pointer;
        font-weight: 600;
    }

        .clear-btn:hover {
            background: #ddd;
        }

    .input {
        padding: 8px 10px;
        border-radius: 10px;
        border: 1px solid #ddd;
        min-width: 220px;
    }

    .results-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 28px;
    }

    .result-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        margin-bottom: 18px;
        transition: 0.2s ease;
    }

        .result-card:hover {
            transform: translateY(-3px);
        }

    .result-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-title {
        font-size: 18px;
        font-weight: 700;
    }

    .score-badge {
        background: #111;
        color: #fff;
        padding: 6px 14px;
        border-radius: 999px;
        font-weight: 700;
    }

    .explain-btn {
        margin-top: 12px;
        padding: 6px 12px;
        border-radius: 8px;
        border: none;
        background: #f1f1f1;
        cursor: pointer;
        font-weight: 600;
    }

        .explain-btn:hover {
            background: #e3e3e3;
        }

    .explain-panel {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #eee;
    }

    .explain-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .map-placeholder {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        height: fit-content;
    }

    .map-box {
        margin-top: 14px;
        height: 420px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .empty-state {
        background: #fff;
        padding: 30px;
        border-radius: 16px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }
</style>

<div class="results-container">

    <div class="results-header">
        <h1>Results</h1>

        <div class="header-actions">
            <form method="post" action="/SavedSearches/SaveCurrent" style="display:flex; gap:8px; align-items:center;">
                <input name="name" class="input" placeholder="Name (e.g., KW groceries 3km)" />
                <button class="clear-btn" type="submit">Save Search</button>
            </form>

            <form method="post" asp-action="Clear">
                <button class="clear-btn" type="submit">Clear All</button>
            </form>
        </div>
    </div>

    <div id="loadingState" class="empty-state" style="display:none;">
        <h3>Loading live results...</h3>
        <p>Fetching nearby places in real time.</p>
    </div>

    <div id="emptyState" class="empty-state" style="display:none;">
        <h3>No results found</h3>
        <p>Try increasing radius or selecting a different location.</p>
    </div>

    <div class="results-layout">
        <div id="resultsList"></div>

        <div class="map-placeholder">
            <strong>Map</strong>
            <div id="resultsMap" class="map-box"></div>
            <div class="hint" style="margin-top:10px;">Live map results (OpenStreetMap).</div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>

<script>
    (async function () {
        const filters = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Filters));
        const lat = filters.Lat;
        const lng = filters.Lng;
        const radiusKm = filters.RadiusKm ?? 3;
        const priorities = (filters.Priorities ?? []).map(p => (p || "").toLowerCase());

        const loading = document.getElementById("loadingState");
        const empty = document.getElementById("emptyState");
        const list = document.getElementById("resultsList");

        function show(el){ if(el) el.style.display = ""; }
        function hide(el){ if(el) el.style.display = "none"; }

        hide(empty);
        show(loading);

        const mapLat = lat ?? 43.4516;
        const mapLng = lng ?? -80.4925;

        const map = L.map("resultsMap").setView([mapLat, mapLng], 13);
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        // ✅ fix size issues
        setTimeout(() => map.invalidateSize(), 200);

        const markersLayer = L.layerGroup().addTo(map);

        if (!lat || !lng) {
            hide(loading);
            show(empty);
            empty.querySelector("p").textContent = "Go back to Filters and pick a location on the map.";
            return;
        }

        // show user location + radius
        L.circle([lat, lng], { radius: radiusKm * 1000 }).addTo(map);
        L.marker([lat, lng]).addTo(map).bindPopup("Selected location").openPopup();

        try {
            const resp = await fetch(`/api/search?lat=${encodeURIComponent(lat)}&lng=${encodeURIComponent(lng)}&radiusKm=${encodeURIComponent(radiusKm)}`);
            if (!resp.ok) throw new Error("Search API failed");
            const data = await resp.json();

            const elements = data.elements || [];
            const pois = elements
                .filter(e => typeof e.lat === "number" && typeof e.lon === "number")
                .map(e => {
                    const tags = e.tags || {};
                    const name = tags.name || "Unnamed place";
                    return { name, lat: e.lat, lng: e.lon, tags };
                });

            function classify(tags) {
                if (tags.shop === "supermarket") return "grocery";
                if (tags.highway === "bus_stop" || tags.amenity === "bus_station") return "transit";
                if (tags.leisure === "fitness_centre") return "gym/fitness";
                if (tags.leisure === "park") return "parks";
                if (tags.amenity === "parking") return "parking";
                if (tags.amenity === "laundry" || tags.shop === "laundry") return "laundry";
                return "other";
            }

            const byCategory = new Map();
            for (const p of pois) {
                const cat = classify(p.tags);
                if (!byCategory.has(cat)) byCategory.set(cat, []);
                byCategory.get(cat).push(p);
            }

            const priorityToCategory = {
                "grocery": "grocery",
                "transit": "transit",
                "gym/fitness": "gym/fitness",
                "parks": "parks",
                "parking": "parking",
                "laundry": "laundry"
            };

            const selectedCats = priorities.map(p => priorityToCategory[p]).filter(Boolean);
            const catsToShow = selectedCats.length ? selectedCats : ["grocery","transit","parks","gym/fitness","laundry","parking"];

            const cards = [];
            for (const cat of catsToShow) {
                const items = (byCategory.get(cat) || []).slice(0, 6);
                if (items.length === 0) continue;

                const score = Math.min(100, 60 + items.length * 6);

                cards.push({
                    name: cat.toUpperCase(),
                    score,
                    pros: [`${items.length} nearby matches within ${radiusKm}km`, "Live OpenStreetMap data"],
                    cons: items.length < 2 ? ["Limited options in this radius"] : [],
                    pois: items
                });
            }

            hide(loading);

            if (cards.length === 0) {
                show(empty);
                list.innerHTML = "";
                return;
            }

            hide(empty);
            list.innerHTML = "";
            markersLayer.clearLayers();

            for (const card of cards) {
                const cardEl = document.createElement("div");
                cardEl.className = "result-card";
                cardEl.innerHTML = `
                    <div class="result-header">
                        <div class="result-title">${card.name}</div>
                        <div class="score-badge">${card.score}</div>
                    </div>

                    <button type="button" class="explain-btn">Explain</button>

                    <div class="explain-panel" style="display:none;">
                        <div class="explain-grid">
                            <div>
                                <strong>Pros</strong>
                                <ul>${card.pros.map(p => `<li>${p}</li>`).join("")}</ul>
                            </div>
                            <div>
                                <strong>Cons</strong>
                                <ul>${card.cons.map(c => `<li>${c}</li>`).join("")}</ul>
                            </div>
                        </div>
                        <div style="margin-top:12px;">
                            <strong>Nearby places</strong>
                            <ul>${card.pois.map(p => `<li>${p.name}</li>`).join("")}</ul>
                        </div>
                    </div>
                `;

                const btn = cardEl.querySelector(".explain-btn");
                const panel = cardEl.querySelector(".explain-panel");
                btn.addEventListener("click", () => {
                    panel.style.display = (panel.style.display === "none" ? "" : "none");
                });

                list.appendChild(cardEl);

                for (const p of card.pois) {
                    L.marker([p.lat, p.lng]).addTo(markersLayer).bindPopup(p.name);
                }
            }

            const bounds = [];
            markersLayer.eachLayer(l => bounds.push(l.getLatLng()));
            if (bounds.length) map.fitBounds(bounds, { padding: [30, 30] });

        } catch (err) {
            hide(loading);
            show(empty);
            empty.querySelector("p").textContent = "Live search failed. Try again or reduce radius.";
            console.error(err);
        }
    })();
</script>