@model List<Shortlist.Web.Models.HousingProvider>
@{
    Layout = "_Layout";
    var q = (ViewBag.Query as string) ?? "";
}

<style>
    :root {
        --bg: #dbe4f3;
        --bg2: #d2ddf0;
        --bg3: #e2e8f6;
        --surface: rgba(255, 255, 255, 0.78);
        --surface-strong: rgba(255, 255, 255, 0.88);
        --surface-soft: rgba(246, 249, 255, 0.72);
        --surface-deep: rgba(232, 239, 250, 0.88);
        --surface-tint: rgba(224, 231, 255, 0.86);
        --border: rgba(100, 116, 139, 0.18);
        --border-strong: rgba(100, 116, 139, 0.28);
        --text: #0f172a;
        --muted: #475569;
        --muted2: #64748b;
        --accent: #4f46e5;
        --accent-hover: #4338ca;
        --accent-soft: rgba(79, 70, 229, 0.14);
        --info: #2563eb;
        --info-soft: rgba(37, 99, 235, 0.12);
        --success: #15803d;
        --success-soft: rgba(21, 128, 61, 0.12);
        --shadow-xl: 0 24px 70px rgba(15, 23, 42, 0.10);
        --shadow-lg: 0 18px 40px rgba(15, 23, 42, 0.08);
        --shadow-md: 0 10px 24px rgba(15, 23, 42, 0.06);
        --focus: 0 0 0 3px rgba(79, 70, 229, 0.18);
    }

    body {
        background: radial-gradient(1200px 700px at 0% -10%, rgba(79, 70, 229, 0.28), transparent 55%), radial-gradient(900px 600px at 100% 0%, rgba(37, 99, 235, 0.22), transparent 50%), radial-gradient(800px 500px at 50% 100%, rgba(14, 165, 233, 0.10), transparent 45%), linear-gradient(180deg, var(--bg) 0%, var(--bg2) 50%, var(--bg3) 100%);
    }

    .shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 18px 16px 28px;
        color: var(--text);
    }

    .hero {
        border: 1px solid var(--border);
        border-radius: 24px;
        background: radial-gradient(760px 280px at 15% 0%, rgba(79,70,229,0.16), transparent 58%), radial-gradient(560px 240px at 92% 18%, rgba(37,99,235,0.10), transparent 54%), linear-gradient(180deg, rgba(245, 248, 255, 0.80), rgba(233, 240, 250, 0.76));
        box-shadow: var(--shadow-lg);
        padding: 20px;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 14px;
        align-items: center;
        backdrop-filter: blur(14px);
    }

    h1 {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.6px;
        font-weight: 950;
        color: var(--text);
    }

    .sub {
        margin-top: 8px;
        color: var(--muted);
        font-weight: 750;
        font-size: 13px;
        line-height: 1.6;
        max-width: 64ch;
    }

    .searchRow {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .input {
        width: min(420px, 100%);
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 11px 12px;
        font-weight: 850;
        outline: none;
        box-shadow: var(--shadow-md);
    }

        .input::placeholder {
            color: var(--muted2);
            font-weight: 750;
        }

        .input:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
        }

    .btn {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 11px 14px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .btn:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,0.92);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .btn:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

        .btn.primary {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            border-color: transparent;
            color: #ffffff;
            box-shadow: 0 14px 34px rgba(79,70,229,0.20);
        }

            .btn.primary:hover {
                background: linear-gradient(135deg, var(--accent-hover), var(--accent));
            }

    .grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    .card {
        border-radius: 22px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.78), rgba(232, 239, 250, 0.74));
        box-shadow: var(--shadow-md);
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 190px;
        backdrop-filter: blur(12px);
    }

    .nameRow {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: flex-start;
    }

    .name {
        font-weight: 950;
        font-size: 16px;
        letter-spacing: -0.2px;
        color: var(--text);
    }

    .city {
        color: var(--muted2);
        font-weight: 850;
        font-size: 12px;
        margin-top: 4px;
    }

    .tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 2px;
    }

    .chip {
        padding: 7px 10px;
        border-radius: 999px;
        border: 1px solid rgba(79, 70, 229, 0.20);
        background: var(--surface-tint);
        color: var(--accent);
        font-weight: 850;
        font-size: 12px;
    }

    .notes {
        color: var(--muted);
        font-weight: 750;
        font-size: 12px;
        line-height: 1.65;
    }

    .linkBtn {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: rgba(248, 250, 255, 0.82);
        color: var(--text);
        padding: 10px 12px;
        font-weight: 900;
        text-decoration: none;
        box-shadow: var(--shadow-md);
        transition: transform .12s ease, background .12s ease, border .12s ease, box-shadow .12s ease;
    }

        .linkBtn:hover {
            transform: translateY(-1px);
            background: rgba(255,255,255,0.92);
            border-color: rgba(99, 102, 241, 0.24);
            box-shadow: var(--shadow-lg);
        }

        .linkBtn:focus-visible {
            outline: none;
            box-shadow: var(--focus);
        }

    .empty {
        margin-top: 16px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(242, 247, 255, 0.78), rgba(232, 239, 250, 0.74));
        padding: 16px;
        color: var(--muted);
        font-weight: 800;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(12px);
    }

    @@media (max-width: 1020px) {
        .hero {
            grid-template-columns: 1fr;
        }

        .grid {
            grid-template-columns: 1fr 1fr;
        }

        .searchRow {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 620px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="shell">
    <section class="hero">
        <div>
            <h1>Housing Providers</h1>
            <div class="sub">
                Real rental sources to help you take action after Shortlist results. Search by city, provider, or tags to quickly find useful housing platforms.
            </div>
        </div>

        <form method="get" class="searchRow">
            <input class="input" name="q" value="@q" placeholder="Search (e.g., Waterloo, student, Accommod8u)" />
            <button class="btn primary" type="submit">Search</button>
            <a class="btn" href="/Housing">Reset</a>
        </form>
    </section>

    @if (Model == null || Model.Count == 0)
    {
        <div class="empty">No providers matched your search. Try a different keyword.</div>
    }
    else
    {
        <section class="grid">
            @foreach (var p in Model)
            {
                <div class="card">
                    <div class="nameRow">
                        <div>
                            <div class="name">@p.Name</div>
                            <div class="city">@p.City</div>
                        </div>
                    </div>

                    <div class="tags">
                        @foreach (var t in (p.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span class="chip">@t</span>
                        }
                    </div>

                    <div class="notes">@p.Notes</div>

                    <a class="linkBtn" href="@p.Url" target="_blank" rel="noopener noreferrer">
                        Open website ↗
                    </a>
                </div>
            }
        </section>
    }
</div>