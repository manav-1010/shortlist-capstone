@{
    Layout = "_LoginLayout";
}

<div style="display: flex; min-height: 100vh;">
    <div style="flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px; background-color: white;">
        <div style="max-width: 400px; width: 100%;">
            <div style="margin-bottom: 40px;">
                <h2 style="font-size: 24px; font-weight: bold; color: black;">Shortlist</h2>
            </div>

            <h1 style="font-size: 32px; margin-bottom: 10px; color: black;">Welcome back!</h1>
            <p style="color: gray; margin-bottom: 30px;">Enter your credentials to access your account</p>

            @if (TempData["ErrorMessage"] != null)
            {
                <div style="padding: 12px; background-color: lightpink; color: darkred; border: 1px solid pink; border-radius: 4px; margin-bottom: 20px;">
                    @TempData["ErrorMessage"]
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="Login">
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; color: black; font-weight: 500;">Email address</label>
                    <input type="email" name="email" required
                           style="width: 100%; padding: 10px; border: 1px solid lightgray; border-radius: 4px; font-size: 14px; box-sizing: border-box;"
                           placeholder="student1@conestogac.on.ca" />
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 5px; color: black; font-weight: 500;">Password</label>
                    <input type="password" name="password" required
                           style="width: 100%; padding: 10px; border: 1px solid lightgray; border-radius: 4px; font-size: 14px; box-sizing: border-box;"
                           placeholder="••••••••" />
                </div>

                <button type="submit"
                        style="width: 100%; padding: 12px; background: orange; color: white; border: none; border-radius: 4px; font-size: 16px; font-weight: 500; cursor: pointer; margin-bottom: 15px; box-sizing: border-box;">
                    Login
                </button>
            </form>

            <div style="text-align: center; margin: 20px 0; color: gray; font-size: 14px;">Or</div>

            <div style="margin-bottom: 20px;">
                <a asp-controller="Account" asp-action="GoogleLogin"
                   style="display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 12px; background: white; color: black; text-decoration: none; border: 1px solid lightgray; border-radius: 4px; font-size: 16px; font-weight: 500; box-sizing: border-box;">
                    <svg width="18" height="18" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                    </svg>
                    Sign in with Google
                </a>
            </div>

            <p style="text-align: center; color: gray; font-size: 14px; margin-top: 30px;">
                Don't have an account? <a asp-controller="Account" asp-action="Register" style="color: orange; text-decoration: none; font-weight: 500;">Sign up</a>
            </p>

            <p style="text-align: center; color: lightgray; font-size: 12px; margin-top: 10px;">
                Demo: test@shortlist.com / password123
            </p>
        </div>
    </div>

    <div style="flex: 1; background-image: url('https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800'); background-size: cover; background-position: center;">
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    button[type="submit"]:hover {
        background: darkorange !important;
    }

    a[asp-action="GoogleLogin"]:hover {
        background: whitesmoke !important;
    }
</style>